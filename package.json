{
  "name": "udyamkings",
  "version": "1.0.0",
  "description": "UdyamKings - Turning Ambition Into Empires",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npm run build:css && nodemon server.js",
    "build": "npm run build:css",
    "build:css": "npx tailwindcss -i ./src/input.css -o ./public/css/tailwind.min.css --minify",
    "watch:css": "npx tailwindcss -i ./src/input.css -o ./public/css/tailwind.min.css --watch",
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:setup": "node test/setup.js",
    "pretest": "npm run test:setup"
  },
  "keywords": [
    "startup",
    "investment",
    "business",
    "funding"
  ],
  "author": "UdyamKings Team",
  "license": "ISC",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^6.0.0",
    "connect-mysql": "^2.1.0",
    "connect-session-sequelize": "^7.1.7",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf": "^3.1.0",
    "csurf": "^1.11.0",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^4.22.1",
