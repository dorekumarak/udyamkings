# Test Environment Configuration
NODE_ENV=test

# Test Database (SQLite for testing)
DB_CLIENT=sqlite3
DB_FILENAME=test-db.sqlite

# Session Configuration for Testing
SESSION_SECRET=test_session_secret

# Email Testing (Ethereal)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=test@example.com
EMAIL_PASSWORD=testpassword
EMAIL_FROM=test@udyamkings.test

# Mock Payment Configuration
RAZORPAY_KEY_ID=rzp_test_mock_key_id
RAZORPAY_KEY_SECRET=rzp_test_mock_key_secret
RAZORPAY_WEBHOOK_SECRET=test_webhook_secret

# File Uploads
MAX_FILE_SIZE=5
UPLOAD_DIR=./test-uploads

# Test Users
TEST_ADMIN_EMAIL=admin@test.com
TEST_ADMIN_PASSWORD=Test@123
TEST_USER_EMAIL=user@test.com
TEST_USER_PASSWORD=User@123
