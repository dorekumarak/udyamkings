<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Payment - UdyamKings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>
<body>
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Complete Your Payment</h4>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <i class="fas fa-credit-card fa-4x text-primary mb-3"></i>
                            <h3>Application Fee Payment</h3>
                            <p class="lead">Amount: ₹<span id="amount"><%= applicationFee %></span></p>
                        </div>

                        <div id="payment-success" class="alert alert-success d-none">
                            <i class="fas fa-check-circle me-2"></i>
                            Payment successful! Redirecting to dashboard...
                        </div>

                        <div id="payment-failure" class="alert alert-danger d-none">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <span id="error-message">Payment failed. Please try again.</span>
                        </div>

                        <div class="d-grid gap-2">
                            <button id="rzp-button" class="btn btn-primary btn-lg">
                                <i class="fas fa-lock me-2"></i>Pay Now - ₹<%= applicationFee %>
                            </button>
                            <a href="/dashboard" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const applicationId = '<%= applicationId %>';
            const amount = <%- applicationFee * 100 %>; // Convert to paise
            
            // Create order when page loads
            fetch('/api/payments/create-order', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': '<%= csrfToken %>'
                },
                body: JSON.stringify({
                    amount: amount / 100, // Convert back to rupees for the server
                    currency: 'INR',
                    receipt: 'receipt_' + applicationId,
                    notes: {
                        applicationId: applicationId
                    }
                })
            })
            .then(response => response.json())
            .then(data => {
                if (!data.success) {
                    throw new Error(data.message || 'Failed to create order');
                }
                
                const order = data.order;
                
                // Configure Razorpay options
                const options = {
                    key: '<%= process.env.RAZORPAY_KEY_ID %>',
                    amount: order.amount,
                    currency: order.currency,
                    name: 'UdyamKings',
                    description: 'Application Fee',
                    order_id: order.id,
                    handler: function(response) {
                        // Handle successful payment
                        document.getElementById('rzp-button').classList.add('d-none');
                        document.getElementById('payment-success').classList.remove('d-none');
                        
                        // Verify payment with server
                        fetch('/api/payments/verify-payment', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-CSRF-Token': '<%= csrfToken %>'
                            },
                            body: JSON.stringify({
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_signature: response.razorpay_signature,
                                applicationId: applicationId
                            })
                        })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                // Redirect to success page after a short delay
                                setTimeout(() => {
                                    window.location.href = '/applications';
                                }, 2000);
                            } else {
                                throw new Error(data.message || 'Payment verification failed');
                            }
                        })
                        .catch(error => {
                            console.error('Payment verification error:', error);
                            document.getElementById('error-message').textContent = 'Payment verification failed: ' + error.message;
                            document.getElementById('payment-failure').classList.remove('d-none');
                        });
                    },
                    prefill: {
                        name: '<%= user.name %>',
                        email: '<%= user.email %>',
                        contact: '<%= user.phone || "" %>'
                    },
                    theme: {
                        color: '#4e73df'
                    }
                };
                
                // Initialize Razorpay
                const rzp = new Razorpay(options);
                
                // Handle payment button click
                document.getElementById('rzp-button').addEventListener('click', function(e) {
                    rzp.open();
                    e.preventDefault();
                });
                
                // Handle payment errors
                rzp.on('payment.failed', function(response) {
                    document.getElementById('error-message').textContent = response.error.description || 'Payment failed. Please try again.';
                    document.getElementById('payment-failure').classList.remove('d-none');
                });
            })
            .catch(error => {
                console.error('Order creation error:', error);
                document.getElementById('error-message').textContent = 'Failed to initialize payment: ' + error.message;
                document.getElementById('payment-failure').classList.remove('d-none');
                document.getElementById('rzp-button').disabled = true;
            });
        });
    </script>
</body>
</html>
