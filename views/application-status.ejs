<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Application Status | UdyamKings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">UdyamKings</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/logout">Logout</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/register">Register</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-body text-center">
                        <h2 class="card-title mb-4">Application Status</h2>
                        
                        <% if (showStatus) { %>
                            <div class="alert alert-info">
                                <h5><%= statusMessage %></h5>
                            </div>
                            
                            <% if (application.application_status === 'accepted') { %>
                                <div class="alert alert-success">
                                    <strong>Congratulations!</strong> Your application has been approved. You will receive further details via email.
                                </div>
                            <% } else if (application.application_status === 'rejected') { %>
                                <div class="alert alert-danger">
                                    <strong>Application Rejected</strong> Unfortunately, your application has been rejected. You can apply again after some time.
                                </div>
                            <% } else if (application.application_status === 'under_review') { %>
                                <div class="alert alert-warning">
                                    <strong>Under Review</strong> Your application is currently being reviewed by our team.
                                </div>
                            <% } %>
                            
                            <div class="mt-4">
                                <a href="/" class="btn btn-primary">Back to Home</a>
                            </div>
                        <% } else { %>
                            <div class="alert alert-warning">
                                <h5><%= statusMessage %></h5>
                            </div>
                            
                            <div class="mt-4">
                                <a href="<%= buttonLink %>" class="btn btn-primary btn-lg"><%= buttonText %></a>
                            </div>
                            
                            <p class="text-muted mt-3">Complete your application to proceed with the funding process.</p>
                        <% } %>
                        
                        <% if (application) { %>
                            <hr>
                            <div class="text-start">
                                <h6>Application Details:</h6>
                                <p><strong>Business Name:</strong> <%= application.business_name %></p>
                                <p><strong>Amount Requested:</strong> ₹<%= application.amount_requested %></p>
                                <p><strong>Submitted:</strong> <%= new Date(application.created_at).toLocaleDateString() %></p>
                                <p><strong>Status:</strong> <%= application.payment_status === 'paid' ? application.application_status : 'Pending Payment' %></p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
