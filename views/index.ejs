<!-- FAQ Section -->
<section class="section bg-light">
    <div class="container">
        <div class="section-title faq-title">
            <h2>Frequently Asked Questions</h2>
            <p>Find answers to common questions about our investment process</p>
        </div>

        <div class="accordion" id="faqAccordion">
            <!-- FAQs will be loaded dynamically -->
        </div>

        <div class="text-center mt-4" id="faqLoading">
            <div class="spinner-border text-primary" role="status">
                <span class="sr-only">Loading FAQs...</span>
            </div>
        </div>

        <div class="text-center mt-4" id="faqEmpty" style="display: none;">
            <p class="text-muted">FAQs will be available soon.</p>
        </div>

        <div style="text-align: center; margin-top: 3rem;">
            <p>Have more questions? <a href="/contact" style="color: var(--primary);">Contact our support team</a></p>
        </div>
    </div>
</section>

<script>
// Load FAQs dynamically from content system
document.addEventListener('DOMContentLoaded', function() {
    loadFAQs();
});

function loadFAQs() {
    const faqAccordion = document.getElementById('faqAccordion');
    const faqLoading = document.getElementById('faqLoading');
    const faqEmpty = document.getElementById('faqEmpty');

    // Show loading
    faqLoading.style.display = 'block';
    faqEmpty.style.display = 'none';

    fetch('/api/v1/content/category/faq')
        .then(response => response.json())
        .then(data => {
            faqLoading.style.display = 'none';

            if (data.success && data.data && data.data.length > 0) {
                // Sort FAQs by order
                const sortedFaqs = data.data.sort((a, b) => (a.order || 0) - (b.order || 0));

                // Render FAQ accordion items
                const faqHtml = sortedFaqs.map((faq, index) => {
                    const [question, answer] = faq.value.split('|').map(s => s.trim());
                    const isFirst = index === 0;
                    const collapseId = `collapse${index + 1}`;
                    const headingId = `heading${index + 1}`;

                    return `
                        <div class="accordion-item">
                            <h3 class="accordion-header" id="${headingId}">
                                <button class="accordion-button ${isFirst ? '' : 'collapsed'}" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#${collapseId}"
                                        aria-expanded="${isFirst}" aria-controls="${collapseId}">
                                    ${question || 'No question'}
                                </button>
                            </h3>
                            <div id="${collapseId}" class="accordion-collapse collapse ${isFirst ? 'show' : ''}"
                                 aria-labelledby="${headingId}" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    ${answer || 'No answer'}
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');

                faqAccordion.innerHTML = faqHtml;
            } else {
                faqEmpty.style.display = 'block';
            }
        })
        .catch(error => {
            console.error('Error loading FAQs:', error);
            faqLoading.style.display = 'none';
            faqEmpty.style.display = 'block';
        });
}
</script>
