                </div>
                
                <div class="col-md-4">
                    <div class="form-section mb-4">
                        <h6 class="section-header">Documents</h6>
                        <div id="documentFields" class="sortable-fields">
                            <% formConfig.fields.filter(f => f.section === 'documents').sort((a, b) => a.order - b.order).forEach(field => { %>
                                <div class="field-item card mb-2" data-field-id="<%= field.id %>">
                                    <div class="card-body p-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="field-handle">
                                                <i class="fas fa-grip-vertical text-muted me-2"></i>
                                                <span><%= field.label %></span>
                                                <% if (field.required) { %>
                                                    <span class="text-danger">*</span>
                                                <% } %>
                                            </div>
                                            <div class="field-actions">
                                                <button type="button" class="btn btn-sm btn-outline-primary edit-field" 
                                                    data-field-id="<%= field.id %>" 
                                                    data-bs-toggle="tooltip" 
                                                    title="Edit Field">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger delete-field" 
                                                    data-field-id="<%= field.id %>"
                                                    data-bs-toggle="tooltip" 
                                                    title="Delete Field">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="field-type-badge">
                                            <span class="badge bg-secondary"><%= field.type %></span>
                                            <% if (field.conditional) { %>
                                                <span class="badge bg-info">Conditional</span>
                                            <% } %>
                                            <% if (field.multiple) { %>
                                                <span class="badge bg-success">Multiple</span>
                                            <% } %>
                                            <% if (field.accept) { %>
                                                <span class="badge bg-primary"><%= field.accept %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="d-flex justify-content-between mt-4">
                <button type="button" class="btn btn-outline-secondary" id="resetForm">
                    <i class="fas fa-undo me-2"></i> Reset to Default
                </button>
                <div>
                    <button type="button" class="btn btn-outline-primary me-2" id="previewForm">
                        <i class="fas fa-eye me-2"></i> Preview Form
                    </button>
                    <button type="button" class="btn btn-primary" id="saveForm" disabled>
                        <i class="fas fa-save me-2"></i> Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- New Field Modal -->
<div class="modal fade" id="newFieldModal" tabindex="-1" aria-labelledby="newFieldModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="newFieldModalLabel">Add New Field</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="fieldForm" action="/admin/form-config/fields" method="POST">
                <div class="modal-body">
                    <ul class="nav nav-tabs mb-4" id="fieldTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="basic-tab" data-bs-toggle="tab" data-bs-target="#basic" type="button" role="tab" aria-controls="basic" aria-selected="true">Basic</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="validation-tab" data-bs-toggle="tab" data-bs-target="#validation" type="button" role="tab" aria-controls="validation" aria-selected="false">Validation</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="conditional-tab" data-bs-toggle="tab" data-bs-target="#conditional" type="button" role="tab" aria-controls="conditional" aria-selected="false">Conditional Logic</button>
                        </li>
                    </ul>
                    
                    <div class="tab-content" id="fieldTabsContent">
                        <!-- Basic Tab -->
                        <div class="tab-pane fade show active" id="basic" role="tabpanel" aria-labelledby="basic-tab">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="fieldLabel" class="form-label">Field Label <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="fieldLabel" name="label" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="fieldName" class="form-label">Field Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="fieldName" name="name" required>
                                    <div class="form-text">Must be unique, no spaces or special characters (use _ for spaces)</div>
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="fieldType" class="form-label">Field Type <span class="text-danger">*</span></label>
                                    <select class="form-select" id="fieldType" name="type" required>
                                        <option value="">Select a field type</option>
                                        <optgroup label="Basic Inputs">
                                            <option value="text">Text</option>
                                            <option value="email">Email</option>
                                            <option value="number">Number</option>
                                            <option value="tel">Phone</option>
                                            <option value="url">URL</option>
                                            <option value="password">Password</option>
                                        </optgroup>
                                        <optgroup label="Selections">
                                            <option value="select">Dropdown</option>
                                            <option value="radio">Radio Buttons</option>
                                            <option value="checkbox">Checkbox</option>
                                            <option value="multiselect">Multi-Select</option>
                                        </optgroup>
                                        <optgroup label="Content">
                                            <option value="textarea">Text Area</option>
                                            <option value="rich_text">Rich Text Editor</option>
                                            <option value="html">HTML</option>
                                        </optgroup>
                                        <optgroup label="Files & Media">
                                            <option value="file">File Upload</option>
                                            <option value="image">Image Upload</option>
                                        </optgroup>
                                        <optgroup label="Date & Time">
                                            <option value="date">Date</option>
                                            <option value="time">Time</option>
                                            <option value="datetime">Date & Time</option>
                                        </optgroup>
                                        <optgroup label="Advanced">
                                            <option value="hidden">Hidden Field</option>
                                            <option value="heading">Heading</option>
                                            <option value="divider">Divider</option>
                                        </optgroup>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="fieldSection" class="form-label">Section <span class="text-danger">*</span></label>
                                    <select class="form-select" id="fieldSection" name="section" required>
                                        <option value="basic">Basic Information</option>
                                        <option value="business">Business Information</option>
                                        <option value="documents">Documents</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div id="optionsContainer" class="mb-3" style="display: none;">
                                <label class="form-label">Options</label>
                                <div id="optionsList">
                                    <!-- Options will be added here dynamically -->
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-secondary mt-2" id="addOption">
                                    <i class="fas fa-plus me-1"></i> Add Option
                                </button>
                            </div>
                            
                            <div class="mb-3" id="fileOptionsContainer" style="display: none;">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="fileAccept" class="form-label">Accepted File Types</label>
                                        <input type="text" class="form-control" id="fileAccept" name="accept" placeholder="e.g., .pdf,.doc,.docx,image/*">
                                        <div class="form-text">Comma-separated list of file extensions or MIME types</div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-check mt-4 pt-2">
                                            <input class="form-check-input" type="checkbox" id="multipleFiles" name="multiple">
                                            <label class="form-check-label" for="multipleFiles">
                                                Allow multiple file uploads
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mt-2">
                                    <div class="col-md-6">
                                        <label for="maxFileSize" class="form-label">Max File Size (MB)</label>
                                        <input type="number" class="form-control" id="maxFileSize" name="maxSize" min="1" value="5">
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="fieldPlaceholder" class="form-label">Placeholder Text</label>
                                <input type="text" class="form-control" id="fieldPlaceholder" name="placeholder">
                            </div>
                            
                            <div class="mb-3">
                                <label for="fieldHelpText" class="form-label">Help Text</label>
                                <textarea class="form-control" id="fieldHelpText" name="helpText" rows="2"></textarea>
                                <div class="form-text">This will appear below the field to provide additional information</div>
                            </div>
                            
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" id="fieldRequired" name="required">
                                <label class="form-check-label" for="fieldRequired">This field is required</label>
                            </div>
                        </div>
                        
                        <!-- Validation Tab -->
                        <div class="tab-pane fade" id="validation" role="tabpanel" aria-labelledby="validation-tab">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                Configure validation rules for this field. Leave empty for no validation.
                            </div>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="validationMin" class="form-label">Minimum Length</label>
                                    <input type="number" class="form-control" id="validationMin" name="validation.min" min="0">
                                </div>
                                <div class="col-md-6">
                                    <label for="validationMax" class="form-label">Maximum Length</label>
                                    <input type="number" class="form-control" id="validationMax" name="validation.max" min="1">
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="validationPattern" class="form-label">Pattern (Regular Expression)</label>
                                <input type="text" class="form-control" id="validationPattern" name="validation.pattern" placeholder="e.g., [A-Za-z]{3}">
                                <div class="form-text">Enter a JavaScript regular expression pattern</div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="validationMessage" class="form-label">Custom Error Message</label>
                                <input type="text" class="form-control" id="validationMessage" name="validation.message" placeholder="e.g., Please enter a valid value">
                            </div>
                        </div>
                        
                        <!-- Conditional Logic Tab -->
                        <div class="tab-pane fade" id="conditional" role="tabpanel" aria-labelledby="conditional-tab">
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                Conditional logic allows you to show/hide this field based on the value of another field.
                            </div>
                            
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" id="enableConditional" name="conditional.enabled">
                                <label class="form-check-label" for="enableConditional">Enable Conditional Logic</label>
                            </div>
                            
                            <div id="conditionalSettings" style="display: none;">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label for="conditionalField" class="form-label">Field to Watch</label>
                                        <select class="form-select" id="conditionalField" name="conditional.field">
                                            <option value="">Select a field</option>
                                            <% formConfig.fields.forEach(field => { %>
                                                <% if (['select', 'radio', 'checkbox'].includes(field.type)) { %>
                                                    <option value="<%= field.name %>"><%= field.label %></option>
                                                <% } %>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="conditionalOperator" class="form-label">Condition</label>
                                        <select class="form-select" id="conditionalOperator" name="conditional.operator">
                                            <option value="===">is equal to</option>
                                            <option value="!==">is not equal to</option>
                                            <option value="contains">contains</option>
                                            <option value="!contains">does not contain</option>
                                        </select>
                                    </div>
                                </div>
                                
                                <div class="mb-3" id="conditionalValueContainer">
                                    <label for="conditionalValue" class="form-label">Value</label>
                                    <input type="text" class="form-control" id="conditionalValue" name="conditional.value">
                                    <div class="form-text">Enter the value to compare against</div>
                                </div>
                                
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="conditionalInverse" name="conditional.inverse">
                                    <label class="form-check-label" for="conditionalInverse">Inverse condition (show when condition is not met)</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Field</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Field Options Template (Hidden) -->
<div id="optionTemplate" style="display: none;">
    <div class="input-group mb-2 option-item">
        <span class="input-group-text">
            <i class="fas fa-grip-vertical handle"></i>
        </span>
        <input type="text" class="form-control" name="options[]" placeholder="Option label" required>
        <input type="text" class="form-control" name="optionValues[]" placeholder="Value (optional)">
        <button type="button" class="btn btn-outline-danger remove-option">
            <i class="fas fa-times"></i>
        </button>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialize Sortable for field reordering
    const sortables = document.querySelectorAll('.sortable-fields');
    sortables.forEach(sortableEl => {
        new Sortable(sortableEl, {
            handle: '.field-handle',
            animation: 150,
            onEnd: function() {
                updateFieldOrders();
            }
        });
    });
    
    // Update field orders in the database
    function updateFieldOrders() {
        const sections = ['basic', 'business', 'documents'];
        const updates = [];
        
        sections.forEach(section => {
            const container = document.getElementById(`${section}Fields`);
            const fields = container.querySelectorAll('.field-item');
            
            fields.forEach((field, index) => {
                const fieldId = field.getAttribute('data-field-id');
                updates.push({
                    id: fieldId,
                    section: section,
                    order: index
                });
            });
        });
        
        // Send update to server
        fetch('/admin/form-config/reorder', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': '<%= csrfToken %>'
            },
            body: JSON.stringify({ fields: updates })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById('saveForm').disabled = false;
            }
        });
    }
    
    // Toggle conditional settings
    const enableConditional = document.getElementById('enableConditional');
    const conditionalSettings = document.getElementById('conditionalSettings');
    
    if (enableConditional && conditionalSettings) {
        enableConditional.addEventListener('change', function() {
            conditionalSettings.style.display = this.checked ? 'block' : 'none';
        });
    }
    
    // Handle field type changes
    const fieldType = document.getElementById('fieldType');
    const optionsContainer = document.getElementById('optionsContainer');
    const fileOptionsContainer = document.getElementById('fileOptionsContainer');
    
    if (fieldType) {
        fieldType.addEventListener('change', function() {
            const type = this.value;
            const showOptions = ['select', 'radio', 'checkbox', 'multiselect'].includes(type);
            const showFileOptions = ['file', 'image'].includes(type);
            
            optionsContainer.style.display = showOptions ? 'block' : 'none';
            fileOptionsContainer.style.display = showFileOptions ? 'block' : 'none';
            
            // Initialize options if needed
            if (showOptions && document.querySelectorAll('.option-item').length === 0) {
                addOption();
                addOption();
            }
        });
    }
    
    // Add option to select/radio/checkbox
    const addOptionBtn = document.getElementById('addOption');
    if (addOptionBtn) {
        addOptionBtn.addEventListener('click', addOption);
    }
    
    function addOption() {
        const optionsList = document.getElementById('optionsList');
        const template = document.getElementById('optionTemplate');
        const newOption = template.cloneNode(true);
        
        newOption.style.display = 'block';
        newOption.classList.remove('option-template');
        newOption.classList.add('option-item');
        
        // Add remove event listener
        const removeBtn = newOption.querySelector('.remove-option');
        if (removeBtn) {
            removeBtn.addEventListener('click', function() {
                this.closest('.option-item').remove();
            });
        }
        
        optionsList.appendChild(newOption);
        
        // Initialize sortable for options
        new Sortable(optionsList, {
            handle: '.handle',
            animation: 150
        });
    }
    
    // Edit field
    document.querySelectorAll('.edit-field').forEach(btn => {
        btn.addEventListener('click', function() {
            const fieldId = this.getAttribute('data-field-id');
            // In a real implementation, this would fetch the field data and populate the modal
            // For now, we'll just show the modal
            const modal = new bootstrap.Modal(document.getElementById('newFieldModal'));
            modal.show();
            
            // Change the form to update instead of create
            const form = document.getElementById('fieldForm');
            form.action = `/admin/form-config/fields/${fieldId}`;
            form.querySelector('button[type="submit"]').textContent = 'Update Field';
            document.getElementById('newFieldModalLabel').textContent = 'Edit Field';
            
            // TODO: Load field data and populate form
        });
    });
    
    // Delete field
    document.querySelectorAll('.delete-field').forEach(btn => {
        btn.addEventListener('click', function() {
            if (confirm('Are you sure you want to delete this field? This action cannot be undone.')) {
                const fieldId = this.getAttribute('data-field-id');
                // In a real implementation, this would send a DELETE request
                fetch(`/admin/form-config/fields/${fieldId}`, {
                    method: 'DELETE',
                    headers: {
                        'X-CSRF-Token': '<%= csrfToken %>',
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Remove the field from the UI
                        document.querySelector(`.field-item[data-field-id="${fieldId}"]`).remove();
                    }
                });
            }
        });
    });
    
    // Preview form
    const previewBtn = document.getElementById('previewForm');
    if (previewBtn) {
        previewBtn.addEventListener('click', function() {
            window.open('/apply/preview', '_blank');
        });
    }
    
    // Reset form to default
    const resetBtn = document.getElementById('resetForm');
    if (resetBtn) {
        resetBtn.addEventListener('click', function() {
            if (confirm('Are you sure you want to reset the form to default? This will remove all custom fields and configurations.')) {
                fetch('/admin/form-config/reset', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '<%= csrfToken %>',
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        window.location.reload();
                    }
                });
            }
        });
    }
    
    // Save form
    const saveBtn = document.getElementById('saveForm');
    if (saveBtn) {
        saveBtn.addEventListener('click', function() {
            // In a real implementation, this would save any pending changes
            this.disabled = true;
            this.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Saving...';
            
            // Simulate API call
            setTimeout(() => {
                this.innerHTML = '<i class="fas fa-check me-2"></i> Changes Saved';
                setTimeout(() => {
                    this.innerHTML = '<i class="fas fa-save me-2"></i> Save Changes';
                }, 2000);
            }, 1000);
        });
    }
    
    // Initialize tooltips
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
});
</script>
