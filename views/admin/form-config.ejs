<%- include('../layouts/admin-layout', { 
    title: 'Form Configuration | UdyamKings Admin', 
    page: 'form-config',
    pageTitle: 'Form Configuration',
    styles: ['/css/admin.css'],
    scripts: [
        'https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.14.0/Sortable.min.js',
        '/js/admin-form-config.js'
    ]
}) %>

<div class="form-config-container">
    <div class="form-config-header">
        <h2>Form Builder</h2>
        <div class="actions">
            <button id="add-field" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add Field
            </button>
            <button id="save-order" class="btn btn-secondary">
                <i class="fas fa-save"></i> Save Order
            </button>
        </div>
    </div>
    
    <div id="form-configs" class="form-config-list">
        <!-- Form configurations will be loaded here by JavaScript -->
    </div>
</div>

<!-- Add/Edit Field Modal -->
<div id="field-modal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modal-title">Add New Field</h2>
            <button type="button" class="modal-close">&times;</button>
        </div>
        <form id="field-form">
            <div class="modal-body">
                <input type="hidden" id="field-id">
                
                <div class="form-group">
                    <label for="field-name" class="form-label">Field Name *</label>
                    <input type="text" id="field-name" class="form-control" required>
                    <small class="text-muted">Must be unique and use camelCase (e.g., businessName)</small>
                </div>
                
                <div class="form-group">
                    <label for="field-label" class="form-label">Field Label *</label>
                    <input type="text" id="field-label" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label for="field-type" class="form-label">Field Type *</label>
                    <select id="field-type" class="form-control" required>
                        <option value="text">Text</option>
                        <option value="textarea">Text Area</option>
                        <option value="number">Number</option>
                        <option value="email">Email</option>
                        <option value="tel">Phone</option>
                        <option value="select">Dropdown</option>
                        <option value="radio">Radio Buttons</option>
                        <option value="checkbox">Checkbox</option>
                        <option value="file">File Upload</option>
                        <option value="date">Date</option>
                    </select>
                </div>
                
                <div class="form-group" id="options-group" style="display: none;">
                    <label for="field-options" class="form-label">Options (one per line)</label>
                    <textarea id="field-options" class="form-control" rows="4"></textarea>
                    <small class="text-muted">Format: value:Label (e.g., "option1:Option 1")</small>
                </div>
                
                <div class="form-group">
                    <label class="form-check">
                        <input type="checkbox" id="is-required" class="form-check-input">
                        <span>Required Field</span>
                    </label>
                </div>
                
                <div class="form-group">
                    <label for="field-order" class="form-label">Display Order</label>
                    <input type="number" id="field-order" class="form-control" min="0" value="0">
                </div>
                
                <div id="file-options" style="display: none;">
                    <div class="form-group">
                        <label class="form-label">Allowed File Types</label>
                        <div class="form-check">
                            <input type="checkbox" id="file-pdf" class="form-check-input" value="application/pdf" checked>
                            <label class="form-check-label" for="file-pdf">PDF</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" id="file-jpg" class="form-check-input" value="image/jpeg" checked>
                            <label class="form-check-label" for="file-jpg">JPG/JPEG</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" id="file-png" class="form-check-input" value="image/png" checked>
                            <label class="form-check-label" for="file-png">PNG</label>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-check">
                            <input type="checkbox" id="multiple-files" class="form-check-input">
                            <span>Allow multiple files</span>
                        </label>
                    </div>
                </div>
                
                <div id="conditional-logic" class="mt-4">
                    <h4>Conditional Logic</h4>
                    <div class="form-group">
                        <label class="form-label">Show this field when:</label>
                        <select id="condition-field" class="form-control mb-2">
                            <option value="">-- Select a field --</option>
                            <!-- Will be populated by JavaScript -->
                        </select>
                        <div id="condition-value-group" style="display: none;">
                            <select id="condition-operator" class="form-control mb-2">
                                <option value="equals">equals</option>
                                <option value="not_equals">does not equal</option>
                            </select>
                            <input type="text" id="condition-value" class="form-control" placeholder="Value">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" id="cancel-edit" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Field</button>
            </div>
        </form>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="confirm-modal" class="modal" style="display: none;">
    <div class="modal-content" style="max-width: 500px;">
        <div class="modal-header">
            <h2 id="confirm-title">Confirm Action</h2>
            <button type="button" class="modal-close">&times;</button>
        </div>
        <div class="modal-body">
            <p id="confirm-message">Are you sure you want to delete this field?</p>
        </div>
        <div class="modal-footer">
            <button type="button" id="confirm-cancel" class="btn btn-secondary">Cancel</button>
            <button type="button" id="confirm-action" class="btn btn-danger">Delete</button>
        </div>
    </div>
</div>

<script>
// Initialize tooltips
$(function () {
    $('[data-bs-toggle="tooltip"]').tooltip();
});

// Show/hide options based on field type
document.getElementById('field-type').addEventListener('change', function() {
    const fieldType = this.value;
    const optionsGroup = document.getElementById('options-group');
    const fileOptions = document.getElementById('file-options');
    
    // Show/hide options for select/radio/checkbox
    if (['select', 'radio', 'checkbox'].includes(fieldType)) {
        optionsGroup.style.display = 'block';
    } else {
        optionsGroup.style.display = 'none';
    }
    
    // Show/hide file options
    if (fieldType === 'file') {
        fileOptions.style.display = 'block';
    } else {
        fileOptions.style.display = 'none';
    }
});

// Handle condition field change
document.getElementById('condition-field').addEventListener('change', function() {
    const conditionValueGroup = document.getElementById('condition-value-group');
    if (this.value) {
        conditionValueGroup.style.display = 'block';
    } else {
        conditionValueGroup.style.display = 'none';
    }
});
</script>
