                                                    data-bs-toggle="tooltip" 
                                                    title="Delete Field">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="field-type-badge">
                                            <span class="badge bg-secondary"><%= field.type %></span>
                                            <% if (field.conditional) { %>
                                                <span class="badge bg-info">Conditional</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <div class="form-section mb-4">
                        <h6 class="section-header">Business Information</h6>
                        <div id="businessFields" class="sortable-fields">
                            <% formConfig.fields.filter(f => f.section === 'business').sort((a, b) => a.order - b.order).forEach(field => { %>
                                <div class="field-item card mb-2" data-field-id="<%= field.id %>">
                                    <div class="card-body p-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="field-handle">
                                                <i class="fas fa-grip-vertical text-muted me-2"></i>
                                                <span><%= field.label %></span>
                                                <% if (field.required) { %>
                                                    <span class="text-danger">*</span>
                                                <% } %>
                                            </div>
                                            <div class="field-actions">
                                                <button type="button" class="btn btn-sm btn-outline-primary edit-field" 
                                                    data-field-id="<%= field.id %>" 
                                                    data-bs-toggle="tooltip" 
                                                    title="Edit Field">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger delete-field" 
                                                    data-field-id="<%= field.id %>"
