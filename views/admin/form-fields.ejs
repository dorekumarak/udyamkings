<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2>Form Field Manager</h2>
            <p class="text-muted">Manage dynamic form fields for application forms</p>
        </div>
        <div class="col-md-6 text-end">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#fieldModal">
                <i class="fas fa-plus me-1"></i> Add Field
            </button>
        </div>
    </div>

    <!-- Form Fields List -->
    <div class="card">
        <div class="card-body">
            <div id="fieldsContainer" class="sortable-container">
                <!-- Form fields will be loaded here -->
            </div>

            <div id="emptyState" class="text-center py-5">
                <i class="fas fa-form fa-3x text-muted mb-3"></i>
                <h5>No Form Fields</h5>
                <p class="text-muted">Start by adding your first form field</p>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#fieldModal">
                    <i class="fas fa-plus me-1"></i> Add First Field
                </button>
            </div>
        </div>
    </div>

    <!-- Add/Edit Field Modal -->
    <div class="modal fade" id="fieldModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="fieldModalTitle">Add Form Field</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="fieldForm">
                        <input type="hidden" id="fieldId" name="fieldId">

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="fieldLabel" class="form-label">Field Label *</label>
                                <input type="text" class="form-control" id="fieldLabel" name="fieldLabel" required>
                            </div>
                            <div class="col-md-6">
                                <label for="fieldName" class="form-label">Field Name *</label>
                                <input type="text" class="form-control" id="fieldName" name="fieldName" required>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="fieldType" class="form-label">Field Type *</label>
                                <select class="form-select" id="fieldType" name="fieldType" required>
                                    <option value="">Select Type</option>
                                    <option value="text">Text Input</option>
                                    <option value="email">Email</option>
                                    <option value="number">Number</option>
                                    <option value="textarea">Textarea</option>
                                    <option value="select">Select Dropdown</option>
                                    <option value="checkbox">Checkbox</option>
                                    <option value="radio">Radio Buttons</option>
                                    <option value="date">Date</option>
                                    <option value="file">File Upload</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="fieldOrder" class="form-label">Display Order</label>
                                <input type="number" class="form-control" id="fieldOrder" name="fieldOrder" min="1">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="fieldPlaceholder" class="form-label">Placeholder Text</label>
                            <input type="text" class="form-control" id="fieldPlaceholder" name="fieldPlaceholder">
                        </div>

                        <div class="mb-3">
                            <label for="fieldOptions" class="form-label">Options (for select/radio)</label>
                            <textarea class="form-control" id="fieldOptions" name="fieldOptions" rows="3" placeholder="One option per line"></textarea>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="fieldRequired" name="fieldRequired">
                                    <label class="form-check-label" for="fieldRequired">
                                        Required Field
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="fieldEnabled" name="fieldEnabled" checked>
                                    <label class="form-check-label" for="fieldEnabled">
                                        Enabled
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="fieldHelpText" class="form-label">Help Text</label>
                            <textarea class="form-control" id="fieldHelpText" name="fieldHelpText" rows="2"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="saveFieldBtn">Save Field</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Load form fields on page load
    loadFormFields();

    // Save field button
    document.getElementById('saveFieldBtn').addEventListener('click', saveField);

    // Reset modal when closed
    document.getElementById('fieldModal').addEventListener('hidden.bs.modal', function() {
        document.getElementById('fieldForm').reset();
        document.getElementById('fieldId').value = '';
        document.getElementById('fieldModalTitle').textContent = 'Add Form Field';
    });
});

function loadFormFields() {
    fetch('/api/form-configs')
    .then(response => response.json())
    .then(data => {
        renderFormFields(data);
    })
    .catch(error => {
        console.error('Error loading form fields:', error);
        showError('Failed to load form fields');
    });
}

function renderFormFields(fields) {
    const container = document.getElementById('fieldsContainer');
    const emptyState = document.getElementById('emptyState');

    if (fields && fields.length > 0) {
        container.style.display = 'block';
        emptyState.style.display = 'none';

        const fieldsHtml = fields.map((field, index) => `
            <div class="card mb-3 field-item" data-id="${field.id}">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="card-title">${field.field_label}</h6>
                            <p class="card-text text-muted small">${field.field_name}</p>
                            <div class="field-preview">
                                <strong>Type:</strong> ${field.field_type} |
                                <strong>Required:</strong> ${field.is_required ? 'Yes' : 'No'} |
                                <strong>Order:</strong> ${field.display_order} |
                                <strong>Status:</strong> ${field.is_active ? 'Active' : 'Inactive'}
                            </div>
                            ${field.placeholder ? `<small class="text-muted">Placeholder: ${field.placeholder}</small>` : ''}
                            ${field.options ? `<small class="text-muted">Options: ${Array.isArray(field.options) ? field.options.join(', ') : 'N/A'}</small>` : ''}
                        </div>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary" onclick="editField(${field.id})" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-outline-danger" onclick="deleteField(${field.id})" title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `).join('');

        container.innerHTML = fieldsHtml;
    } else {
        container.style.display = 'none';
        emptyState.style.display = 'block';
    }
}

function editField(fieldId) {
    // Load field data and open modal for editing
    fetch(`/api/form-configs/${fieldId}`)
    .then(response => response.json())
    .then(data => {
        document.getElementById('fieldId').value = data.id;
        document.getElementById('fieldLabel').value = data.field_label;
        document.getElementById('fieldName').value = data.field_name;
        document.getElementById('fieldType').value = data.field_type;
        document.getElementById('fieldOrder').value = data.display_order || '';
        document.getElementById('fieldPlaceholder').value = data.placeholder || '';
        document.getElementById('fieldOptions').value = data.options ? (Array.isArray(data.options) ? data.options.join('\n') : '') : '';
        document.getElementById('fieldRequired').checked = data.is_required;
        document.getElementById('fieldEnabled').checked = data.is_active;
        document.getElementById('fieldModalTitle').textContent = 'Edit Form Field';
        new bootstrap.Modal(document.getElementById('fieldModal')).show();
    })
    .catch(error => {
        console.error('Error loading field:', error);
        showError('Failed to load field');
    });
}

function deleteField(fieldId) {
    if (confirm('Are you sure you want to delete this form field?')) {
        fetch(`/api/form-configs/${fieldId}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            showSuccess('Form field deleted successfully');
            loadFormFields();
        })
        .catch(error => {
            console.error('Error deleting field:', error);
            showError('Failed to delete field');
        });
    }
}

function saveField() {
    const form = document.getElementById('fieldForm');
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }

    const fieldId = document.getElementById('fieldId').value;
    const isEdit = fieldId !== '';

    const fieldData = {
        field_name: document.getElementById('fieldName').value,
        field_label: document.getElementById('fieldLabel').value,
        field_type: document.getElementById('fieldType').value,
        display_order: parseInt(document.getElementById('fieldOrder').value) || 0,
        placeholder: document.getElementById('fieldPlaceholder').value,
        options: document.getElementById('fieldOptions').value ? document.getElementById('fieldOptions').value.split('\n').map(opt => opt.trim()).filter(opt => opt) : null,
        is_required: document.getElementById('fieldRequired').checked,
        is_active: document.getElementById('fieldEnabled').checked,
        applicant_types: ['all'] // Default to all applicant types
    };

    const url = isEdit ? `/api/form-configs/${fieldId}` : '/api/form-configs';
    const method = isEdit ? 'PUT' : 'POST';

    fetch(url, {
        method: method,
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(fieldData)
    })
    .then(response => response.json())
    .then(data => {
        bootstrap.Modal.getInstance(document.getElementById('fieldModal')).hide();
        showSuccess(isEdit ? 'Form field updated successfully' : 'Form field created successfully');
        loadFormFields();
    })
    .catch(error => {
        console.error('Error saving field:', error);
        showError('Failed to save form field');
    });
}

// Helper functions
function showSuccess(message) {
    // You can implement a toast notification here
    console.log(message);
    alert(message);
}

function showError(message) {
    // You can implement a toast notification here
    console.error(message);
    alert('Error: ' + message);
}
</script>
