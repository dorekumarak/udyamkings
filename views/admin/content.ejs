<script>
// FAQ Management Functions
function loadFAQs() {
    fetch('/api/v1/admin/content/category/faq')
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            renderFAQList(data.data);
        }
    })
    .catch(error => {
        console.error('Error loading FAQs:', error);
        showError('Failed to load FAQs');
    });
}

function renderFAQList(faqs) {
    const faqList = document.getElementById('faqList');
    const emptyState = document.getElementById('faqEmptyState');

    if (faqs && faqs.length > 0) {
        faqList.style.display = 'block';
        emptyState.style.display = 'none';

        const faqHtml = faqs.sort((a, b) => a.order - b.order).map((faq, index) => `
            <div class="card mb-3 faq-item" data-id="${faq.id}" data-order="${faq.order}">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="card-title">${faq.key}</h6>
                            <p class="card-text text-muted small">${faq.description || 'No description'}</p>
                            <div class="faq-preview">
                                <strong>Q:</strong> ${truncateText(faq.value.split('|')[0] || 'No question', 100)}<br>
                                <strong>A:</strong> ${truncateText(faq.value.split('|')[1] || 'No answer', 150)}
                            </div>
                        </div>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary" onclick="editFAQ(${faq.id})" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-outline-danger" onclick="deleteFAQ(${faq.id})" title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `).join('');

        faqList.innerHTML = faqHtml;
    } else {
        faqList.style.display = 'none';
        emptyState.style.display = 'block';
    }
}

function addNewFAQ() {
    resetContentForm();
    document.getElementById('contentCategory').value = 'faq';
    document.getElementById('contentType').value = 'text';
    document.getElementById('contentKey').value = `faq_${Date.now()}`;
    document.getElementById('contentDescription').value = 'FAQ question and answer';
    document.getElementById('contentValue').value = 'Question text here | Answer text here';
    document.getElementById('contentModalTitle').textContent = 'Add FAQ';
    new bootstrap.Modal(document.getElementById('contentModal')).show();
}

function editFAQ(faqId) {
    // Load FAQ data and open modal for editing
    fetch(`/api/v1/admin/content/${faqId}`)
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const faq = data.data;
            document.getElementById('contentId').value = faq.id;
            document.getElementById('contentKey').value = faq.key;
            document.getElementById('contentCategory').value = faq.category;
            document.getElementById('contentDescription').value = faq.description;
            document.getElementById('contentType').value = faq.type;
            document.getElementById('contentValue').value = faq.value;
            document.getElementById('isContentActive').checked = faq.is_active;
            document.getElementById('contentModalTitle').textContent = 'Edit FAQ';
            new bootstrap.Modal(document.getElementById('contentModal')).show();
        }
    })
    .catch(error => {
        console.error('Error loading FAQ:', error);
        showError('Failed to load FAQ');
    });
}

function deleteFAQ(faqId) {
    if (confirm('Are you sure you want to delete this FAQ?')) {
        fetch(`/api/v1/admin/content/${faqId}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showSuccess('FAQ deleted successfully');
                loadFAQs();
            } else {
                showError(data.message || 'Failed to delete FAQ');
            }
        })
        .catch(error => {
            console.error('Error deleting FAQ:', error);
            showError('Failed to delete FAQ');
        });
    }
}

function truncateText(text, maxLength) {
    return text.length > maxLength ? text.substring(0, maxLength) + '...' : text;
}

// Global variables
let currentContentId = null;
let contentData = {};

// Initialize
document.addEventListener('DOMContentLoaded', function() {
    // Load initial content for active tab
    const activeTab = document.querySelector('.tab-pane.active');
    const activeTabId = activeTab ? activeTab.id : 'homepage';
    loadContentByCategory(activeTabId);

    // Tab change handler
    const tabLinks = document.querySelectorAll('#contentTabs a[data-bs-toggle="tab"]');
    tabLinks.forEach(link => {
        link.addEventListener('shown.bs.tab', function (e) {
            const category = e.target.getAttribute('data-category');
            if (category === 'faq') {
                loadFAQs();
            } else {
                loadContentByCategory(category);
            }
        });
    });

    // Save content button
    document.getElementById('saveContentBtn').addEventListener('click', function() {
        saveContent();
    });

    // Content type change handler
    document.getElementById('contentType').addEventListener('change', function() {
        const type = this.value;
        const valueField = document.getElementById('contentValue');

        if (type === 'color') {
            const newField = document.createElement('input');
            newField.type = 'color';
            newField.className = 'form-control';
            newField.id = 'contentValue';
            newField.required = true;
            valueField.parentNode.replaceChild(newField, valueField);
        } else {
            const newField = document.createElement('textarea');
            newField.className = 'form-control';
            newField.id = 'contentValue';
            newField.rows = 5;
            newField.required = true;
            valueField.parentNode.replaceChild(newField, valueField);
        }
    });
});

// Load content by category
function loadContentByCategory(category) {
    fetch(`/api/v1/admin/content/category/${category}`)
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            contentData[category] = data.data;
            populateContentFields(category);
            renderContentList(category);
        }
    })
    .catch(error => {
        console.error('Error loading content:', error);
        showError('Failed to load content');
    });
}

// Render content list for any category
function renderContentList(category) {
    const content = contentData[category] || [];
    const listContainer = document.getElementById(`${category}ContentList`);
    
    if (!listContainer) return;
    
    const emptyState = listContainer.querySelector('.text-center');
    
    if (content && content.length > 0) {
        if (emptyState) emptyState.style.display = 'none';
        
        const contentHtml = content.map((item, index) => `
            <div class="card mb-3 content-item" data-id="${item.id}">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h6 class="card-title">${item.key}</h6>
                            <p class="card-text text-muted small">${item.description || 'No description'}</p>
                            <div class="content-preview">
                                <strong>Value:</strong> ${truncateText(item.value, 100)}
                            </div>
                            <small class="text-muted">Type: ${item.type} | Status: ${item.is_active ? 'Active' : 'Inactive'}</small>
                        </div>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary" onclick="editContent(${item.id})" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-outline-danger" onclick="deleteContent(${item.id})" title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `).join('');
        
        listContainer.innerHTML = contentHtml;
    } else {
        if (emptyState) {
            emptyState.innerHTML = `
                <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                <h6>No ${category} content added yet</h6>
                <p class="text-muted">Create your first ${category} content item.</p>
                <button type="button" class="btn btn-primary" onclick="addNewContent('${category}')">
                    <i class="fas fa-plus me-1"></i> Add ${category.charAt(0).toUpperCase() + category.slice(1)} Content
                </button>
            `;
            emptyState.style.display = 'block';
        } else {
            listContainer.innerHTML = `
                <div class="text-center py-4">
                    <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                    <h6>No ${category} content added yet</h6>
                    <p class="text-muted">Create your first ${category} content item.</p>
                    <button type="button" class="btn btn-primary" onclick="addNewContent('${category}')">
                        <i class="fas fa-plus me-1"></i> Add ${category.charAt(0).toUpperCase() + category.slice(1)} Content
                    </button>
                </div>
            `;
        }
    }
}

// Add new content
function addNewContent(category) {
    resetContentForm();
    document.getElementById('contentCategory').value = category;
    document.getElementById('contentType').value = 'text';
    document.getElementById('contentKey').value = `${category}_${Date.now()}`;
    document.getElementById('contentDescription').value = `${category} content item`;
    document.getElementById('contentModalTitle').textContent = `Add ${category.charAt(0).toUpperCase() + category.slice(1)} Content`;
    new bootstrap.Modal(document.getElementById('contentModal')).show();
}

// Edit content
function editContent(contentId) {
    // Load content data and open modal for editing
    fetch(`/api/v1/admin/content/${contentId}`)
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const content = data.data;
            document.getElementById('contentId').value = content.id;
            document.getElementById('contentKey').value = content.key;
            document.getElementById('contentCategory').value = content.category;
            document.getElementById('contentDescription').value = content.description;
            document.getElementById('contentType').value = content.type;
            document.getElementById('contentValue').value = content.value;
            document.getElementById('isContentActive').checked = content.is_active;
            document.getElementById('contentModalTitle').textContent = `Edit ${content.category.charAt(0).toUpperCase() + content.category.slice(1)} Content`;
            new bootstrap.Modal(document.getElementById('contentModal')).show();
        }
    })
    .catch(error => {
        console.error('Error loading content:', error);
        showError('Failed to load content');
    });
}

// Delete content
function deleteContent(contentId) {
    if (confirm('Are you sure you want to delete this content item?')) {
        fetch(`/api/v1/admin/content/${contentId}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showSuccess('Content deleted successfully');
                // Reload the current category
                const category = getCurrentCategory();
                loadContentByCategory(category);
            } else {
                showError(data.message || 'Failed to delete content');
            }
        })
        .catch(error => {
            console.error('Error deleting content:', error);
            showError('Failed to delete content');
        });
    }
}

// Populate content fields
function populateContentFields(category) {
    const content = contentData[category] || [];

    content.forEach(item => {
        const field = document.querySelector(`[data-key="${item.key}"]`);
        if (field) {
            if (field.type === 'color') {
                field.value = item.value;
            } else {
                field.value = item.value;
            }
            field.setAttribute('data-id', item.id);
        }
    });
}

// Update content
function updateContent(field) {
    const key = field.getAttribute('data-key');
    const value = field.value;
    const id = field.getAttribute('data-id');

    if (id) {
        // Update existing content
        fetch(`/api/v1/admin/content/${id}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ value })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                field.setAttribute('data-id', data.data.id);
                showSuccess('Content updated successfully');
                // Reload category data
                loadContentByCategory(category);
            }
        })
        .catch(error => {
            console.error('Error updating content:', error);
            showError('Failed to update content');
        });
    } else {
        // Create new content
        const category = getCurrentCategory();
        fetch('/api/v1/admin/content', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                key,
                value,
                category,
                description: key,
                type: 'text'
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                field.setAttribute('data-id', data.data.id);
                showSuccess('Content created successfully');
                // Reload category data
                loadContentByCategory(category);
            }
        })
        .catch(error => {
            console.error('Error creating content:', error);
            showError('Failed to create content');
        });
    }
}

// Save content from modal
function saveContent() {
    const contentId = document.getElementById('contentId').value;
    const isEdit = contentId !== '';

    const contentData = {
        key: document.getElementById('contentKey').value,
        value: document.getElementById('contentValue').value,
        category: document.getElementById('contentCategory').value,
        description: document.getElementById('contentDescription').value,
        type: document.getElementById('contentType').value,
        is_active: document.getElementById('isContentActive').checked
    };

    const url = isEdit
        ? `/api/v1/admin/content/${contentId}`
        : '/api/v1/admin/content';
    const method = isEdit ? 'PUT' : 'POST';

    fetch(url, {
        method: method,
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(contentData)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('contentModal')).hide();
            showSuccess(isEdit ? 'Content updated successfully' : 'Content created successfully');

            // Reload the current category
            const category = getCurrentCategory();
            loadContentByCategory(category);

            // Reset form
            resetContentForm();
        } else {
            showError(data.message || 'Failed to save content');
        }
    })
    .catch(error => {
        console.error('Error saving content:', error);
        showError('Failed to save content');
    });
}

// Get current category
function getCurrentCategory() {
    const activeTab = document.querySelector('.tab-pane.active');
    return activeTab ? activeTab.id : 'homepage';
}

// Reset content form
function resetContentForm() {
    const form = document.getElementById('contentForm');
    form.reset();
    document.getElementById('contentId').value = '';
    document.getElementById('contentModalTitle').textContent = 'Add Content';
    currentContentId = null;
}

// Show success message
function showSuccess(message) {
    // You can implement a toast notification here
    console.log(message);
}

// Show error message
function showError(message) {
    // You can implement a toast notification here
    console.error(message);
}
</script>
