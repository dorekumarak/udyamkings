<div class="dashboard-container">
    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card bg-primary">
            <div class="stat-icon">
                <i class="fas fa-file-alt"></i>
            </div>
            <div class="stat-info">
                <h3>Total Applications</h3>
                <p class="stat-number"><%= stats.total_applications || 0 %></p>
            </div>
        </div>
        
        <div class="stat-card bg-success">
            <div class="stat-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-info">
                <h3>Approved</h3>
                <p class="stat-number"><%= stats.accepted_applications || 0 %></p>
            </div>
        </div>
        
        <div class="stat-card bg-warning">
            <div class="stat-icon">
                <i class="fas fa-clock"></i>
            </div>
            <div class="stat-info">
                <h3>Pending Review</h3>
                <p class="stat-number"><%= stats.pending_applications || 0 %></p>
            </div>
        </div>
        
        <div class="stat-card bg-danger">
            <div class="stat-icon">
                <i class="fas fa-times-circle"></i>
            </div>
            <div class="stat-info">
                <h3>Rejected</h3>
                <p class="stat-number"><%= stats.rejected_applications || 0 %></p>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4>Applications Overview</h4>
                </div>
                <div class="card-body">
                    <canvas id="applicationsChart" height="300"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h4>Application Status</h4>
                </div>
                <div class="card-body">
                    <canvas id="statusChart" height="300"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Applications -->
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>Recent Applications</h4>
            <a href="/admin/applications" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <div class="card-body">
            <% if (recentApplications && recentApplications.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Business Name</th>
                                <th>Applicant</th>
                                <th>Amount</th>
                                <th>Payment Status</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentApplications.forEach(app => { %>
                                <tr>
                                    <td>#<%= app.id %></td>
                                    <td><%= app.business_name %></td>
                                    <td><%= app.user ? app.user.name : 'N/A' %></td>
                                    <td>₹<%= app.amount_requested.toLocaleString('en-IN') %></td>
                                    <td>
                                        <span class="badge bg-<%= 
                                            app.payment_status === 'paid' ? 'success' : 
                                            app.payment_status === 'failed' ? 'danger' : 'secondary' 
                                        %>">
                                            <%= app.payment_status ? app.payment_status.charAt(0).toUpperCase() + app.payment_status.slice(1) : 'Pending' %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-<%= 
                                            app.application_status === 'accepted' ? 'success' : 
                                            app.application_status === 'rejected' ? 'danger' : 'warning' 
                                        %>">
                                            <%= app.application_status.charAt(0).toUpperCase() + app.application_status.slice(1) %>
                                        </span>
                                    </td>
                                    <td><% const d = app.createdAt || app.created_at; const dt = d ? new Date(d) : null; %><%= dt && !isNaN(dt) ? dt.toLocaleDateString() : '' %></td>
                                    <td>
                                        <a href="/admin/applications/<%= app.id %>" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-4">
                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No applications found</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script src="/js/chart.min.js"></script>

<script>
// Initialize charts when the page loads
document.addEventListener('DOMContentLoaded', function() {
    // Applications Overview Chart (Line Chart)
    const ctx1 = document.getElementById('applicationsChart').getContext('2d');
    new Chart(ctx1, {
        type: 'line',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
            datasets: [{
                label: 'Applications',
                data: [12, 19, 15, 25, 22, 30, 28, 35, 30, 40, 45, 50],
                borderColor: 'rgba(75, 192, 192, 1)',
                backgroundColor: 'rgba(75, 192, 192, 0.1)',
                tension: 0.3,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    mode: 'index',
                    intersect: false,
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        precision: 0
                    }
                }
            }
        }
    });

    // Application Status Chart (Doughnut)
    const ctx2 = document.getElementById('statusChart').getContext('2d');
    new Chart(ctx2, {
        type: 'doughnut',
        data: {
            labels: ['Approved', 'Pending', 'Rejected'],
            datasets: [{
                data: [
                    <%= stats.accepted_applications || 0 %>, 
                    <%= stats.pending_applications || 0 %>, 
                    <%= stats.rejected_applications || 0 %>
                ],
                backgroundColor: [
                    'rgba(40, 167, 69, 0.8)',
                    'rgba(255, 193, 7, 0.8)',
                    'rgba(220, 53, 69, 0.8)'
                ],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            },
            cutout: '70%'
        }
    });
});
</script>
