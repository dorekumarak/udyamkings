<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Applicants - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="bg-gray-50">
    <div class="flex h-screen">
        <!-- Sidebar -->
        <%- include('../partials/admin-sidebar') %>
        
        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto">
            <header class="bg-white shadow-sm border-b">
                <div class="px-6 py-4">
                    <h1 class="text-2xl font-semibold text-gray-900">Applicants Management</h1>
                </div>
            </header>
            
            <div class="p-6">
                <!-- Filters and Search -->
                <div class="bg-white rounded-lg shadow p-4 mb-6">
                    <form id="filterForm" class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Search</label>
                            <input 
                                type="text" 
                                name="search" 
                                placeholder="Name, Email, Business..."
                                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500"
                                value="<%= typeof search !== 'undefined' ? search : '' %>"
                            >
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Applicant Type</label>
                            <select name="type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                <option value="">All Types</option>
                                <option value="individual" <%= typeof type !== 'undefined' && type === 'individual' ? 'selected' : '' %>>Individual</option>
                                <option value="partnership" <%= typeof type !== 'undefined' && type === 'partnership' ? 'selected' : '' %>>Partnership</option>
                                <option value="company" <%= typeof type !== 'undefined' && type === 'company' ? 'selected' : '' %>>Company</option>
                            </select>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Payment Status</label>
                            <select name="payment_status" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                <option value="">All Status</option>
                                <option value="pending" <%= typeof payment_status !== 'undefined' && payment_status === 'pending' ? 'selected' : '' %>>Pending</option>
                                <option value="paid" <%= typeof payment_status !== 'undefined' && payment_status === 'paid' ? 'selected' : '' %>>Paid</option>
                                <option value="failed" <%= typeof payment_status !== 'undefined' && payment_status === 'failed' ? 'selected' : '' %>>Failed</option>
                            </select>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Application Status</label>
                            <select name="application_status" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                <option value="">All Status</option>
                                <option value="pending" <%= typeof application_status !== 'undefined' && application_status === 'pending' ? 'selected' : '' %>>Pending</option>
                                <option value="under_review" <%= typeof application_status !== 'undefined' && application_status === 'under_review' ? 'selected' : '' %>>Under Review</option>
                                <option value="accepted" <%= typeof application_status !== 'undefined' && application_status === 'accepted' ? 'selected' : '' %>>Accepted</option>
                                <option value="rejected" <%= typeof application_status !== 'undefined' && application_status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                            </select>
                        </div>
                        
                        <div class="md:col-span-4 flex gap-2">
                            <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700">
                                <i class="fas fa-filter mr-2"></i>Filter
                            </button>
                            <button type="button" onclick="exportCSV()" class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700">
                                <i class="fas fa-download mr-2"></i>Export CSV
                            </button>
                            <button type="button" onclick="clearFilters()" class="px-4 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700">
                                <i class="fas fa-times mr-2"></i>Clear
                            </button>
                        </div>
                    </form>
                </div>
                
                <!-- Applicants Table -->
                <div class="bg-white rounded-lg shadow overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Mobile</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Payment</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% if (typeof applicants !== 'undefined' && applicants.length > 0) { %>
                                    <% applicants.forEach(function(applicant) { %>
                                        <tr class="hover:bg-gray-50">
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                                <%= applicant.id %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                                <%= applicant.user ? applicant.user.name : 'N/A' %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                                <%= applicant.user ? applicant.user.phone : 'N/A' %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                                <%= applicant.user ? applicant.user.email : 'N/A' %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                                                    <%= applicant.applicant_type %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                                ₹<%= applicant.amount_requested || 0 %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                                    <%= applicant.payment_status === 'paid' ? 'bg-green-100 text-green-800' : 
                                                       applicant.payment_status === 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                                                       'bg-red-100 text-red-800' %>">
                                                    <%= applicant.payment_status %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                                    <%= applicant.application_status === 'accepted' ? 'bg-green-100 text-green-800' : 
                                                       applicant.application_status === 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                                                       applicant.application_status === 'rejected' ? 'bg-red-100 text-red-800' : 
                                                       'bg-blue-100 text-blue-800' %>">
                                                    <%= applicant.application_status %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                                <%= new Date(applicant.created_at).toLocaleDateString() %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                                <div class="flex space-x-2">
                                                    <button onclick="viewDetails(<%= applicant.id %>)" class="text-indigo-600 hover:text-indigo-900" title="View Details">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                    <% if (applicant.aadhar_card) { %>
                                                        <button onclick="downloadAadhar(<%= applicant.id %>)" class="text-green-600 hover:text-green-900" title="Download Aadhar">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                    <% } %>
                                                    <% if (applicant.payment_status === 'paid' && applicant.application_status === 'pending') { %>
                                                        <button onclick="acceptApplication(<%= applicant.id %>)" class="text-green-600 hover:text-green-900" title="Accept">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                        <button onclick="rejectApplication(<%= applicant.id %>)" class="text-red-600 hover:text-red-900" title="Reject">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    <% } %>
                                                    <button onclick="addNote(<%= applicant.id %>)" class="text-gray-600 hover:text-gray-900" title="Add Note">
                                                        <i class="fas fa-sticky-note"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="10" class="px-6 py-4 text-center text-gray-500">
                                            No applicants found
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Pagination -->
                    <% if (typeof pagination !== 'undefined') { %>
                        <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6">
                            <div class="flex-1 flex justify-between sm:hidden">
                                <button onclick="changePage(<%= Math.max(1, pagination.page - 1) %>)" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                                    Previous
                                </button>
                                <button onclick="changePage(<%= Math.min(pagination.pages, pagination.page + 1) %>)" class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                                    Next
                                </button>
                            </div>
                            <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                                <div>
                                    <p class="text-sm text-gray-700">
                                        Showing <span class="font-medium"><%= ((pagination.page - 1) * pagination.limit) + 1 %></span> to 
                                        <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span> of 
                                        <span class="font-medium"><%= pagination.total %></span> results
                                    </p>
                                </div>
                                <div>
                                    <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                        <% for (let i = 1; i <= pagination.pages; i++) { %>
                                            <% if (i === pagination.page) { %>
                                                <span class="relative inline-flex items-center px-4 py-2 border border-indigo-500 text-sm font-medium text-indigo-600 bg-indigo-50">
                                                    <%= i %>
                                                </span>
                                            <% } else { %>
                                                <button onclick="changePage(<%= i %>)" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium text-gray-500 bg-white hover:bg-gray-50">
                                                    <%= i %>
                                                </button>
                                            <% } %>
                                        <% } %>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>
    
    <script>
        function viewDetails(id) {
            window.location.href = `/admin/applicants/${id}`;
        }
        
        function downloadAadhar(id) {
            window.location.href = `/admin/applicants/${id}/download/aadhar`;
        }
        
        function acceptApplication(id) {
            if (confirm('Are you sure you want to accept this application?')) {
                updateStatus(id, 'accepted');
            }
        }
        
        function rejectApplication(id) {
            const reason = prompt('Please enter rejection reason:');
            if (reason) {
                updateStatus(id, 'rejected', reason);
            }
        }
        
        function addNote(id) {
            const note = prompt('Enter admin note:');
            if (note) {
                // TODO: Implement add note functionality
                alert('Note added: ' + note);
            }
        }
        
        function updateStatus(id, status, note = '') {
            fetch(`/admin/applicants/${id}/status`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': document.querySelector('input[name="_csrf"]').value
                },
                body: JSON.stringify({
                    status: status,
                    notes: note
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to update status');
            });
        }
        
        function changePage(page) {
            const form = document.getElementById('filterForm');
            const url = new URL(window.location);
            url.searchParams.set('page', page);
            window.location.href = url.toString();
        }
        
        function exportCSV() {
            const form = document.getElementById('filterForm');
            const formData = new FormData(form);
            const params = new URLSearchParams(formData);
            window.location.href = `/admin/applicants/export/csv?${params.toString()}`;
        }
        
        function clearFilters() {
            window.location.href = '/admin/applicants';
        }
    </script>
</body>
</html>
