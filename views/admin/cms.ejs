<%- include('includes/header') %>
<%- include('includes/sidebar') %>

<!-- Main Content -->
<div id="content">
    <!-- Topbar -->
    <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">
        <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
            <i class="fa fa-bars"></i>
        </button>
        <h1 class="h3 mb-0 text-gray-800">Content Management System</h1>
    </nav>

    <!-- Begin Page Content -->
    <div class="container-fluid">
        <!-- Page Heading -->
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
            <h1 class="h3 mb-0 text-gray-800">Content Management</h1>
            <div class="d-flex">
                <button class="btn btn-primary btn-sm mr-2" data-toggle="modal" data-target="#addContentModal">
                    <i class="fas fa-plus fa-sm"></i> Add New
                </button>
            </div>
        </div>

        <!-- Content Tabs -->
        <ul class="nav nav-tabs mb-4" id="contentTabs" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" id="pages-tab" data-toggle="tab" href="#pages" role="tab">Pages</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="blog-tab" data-toggle="tab" href="#blog" role="tab">Blog Posts</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="media-tab" data-toggle="tab" href="#media" role="tab">Media Library</a>
            </li>
        </ul>

        <!-- Tab Content -->
        <div class="tab-content" id="contentTabsContent">
            <!-- Pages Tab -->
            <div class="tab-pane fade show active" id="pages" role="tabpanel">
                <div class="card shadow mb-4">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">Website Pages</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover" id="pagesTable" width="100%" cellspacing="0">
                                <thead>
                                    <tr>
                                        <th>Page Title</th>
                                        <th>URL</th>
                                        <th>Last Modified</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Homepage</td>
                                        <td>/</td>
                                        <td>2023-12-05</td>
                                        <td><span class="badge badge-success">Published</span></td>
                                        <td>
                                            <a href="#" class="btn btn-sm btn-primary"><i class="fas fa-edit"></i></a>
                                            <a href="/" target="_blank" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                                        </td>
                                    </tr>
                                    <!-- More pages would be loaded dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Blog Posts Tab -->
            <div class="tab-pane fade" id="blog" role="tabpanel">
                <div class="card shadow mb-4">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">Blog Posts</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover" id="blogTable">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Author</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Getting Started with UdyamKings</td>
                                        <td>Admin</td>
                                        <td>2023-12-05</td>
                                        <td><span class="badge badge-success">Published</span></td>
                                        <td>
                                            <a href="#" class="btn btn-sm btn-primary"><i class="fas fa-edit"></i></a>
                                            <a href="#" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                                        </td>
                                    </tr>
                                    <!-- More posts would be loaded dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Media Library Tab -->
            <div class="tab-pane fade" id="media" role="tabpanel">
                <div class="card shadow mb-4">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">Media Library</h6>
                        <button class="btn btn-primary btn-sm" data-toggle="modal" data-target="#uploadMediaModal">
                            <i class="fas fa-upload fa-sm"></i> Add New
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="row" id="mediaGrid">
                            <!-- Media items will be loaded here -->
                            <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-4">
                                <div class="card h-100">
                                    <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Media">
                                    <div class="card-body p-2">
                                        <h6 class="card-title text-truncate">Sample Image</h6>
                                        <p class="card-text small text-muted">250 KB • 300 × 200</p>
                                    </div>
                                </div>
                            </div>
                            <!-- More media items would be loaded dynamically -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Content Modal -->
<div class="modal fade" id="addContentModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Content</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="addContentForm">
                    <div class="form-group">
                        <label>Content Type</label>
                        <select class="form-control" id="contentType">
                            <option value="page">Page</option>
                            <option value="post">Blog Post</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Title</label>
                        <input type="text" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>Content</label>
                        <textarea class="form-control" rows="10"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary">Publish</button>
            </div>
        </div>
    </div>
</div>

<!-- Upload Media Modal -->
<div class="modal fade" id="uploadMediaModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Upload Media</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="text-center p-4 border rounded" id="dropZone">
                    <i class="fas fa-cloud-upload-alt fa-3x mb-3 text-muted"></i>
                    <p>Drag & drop files here or click to select</p>
                    <input type="file" id="fileInput" style="display: none;">
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('includes/footer') %>

<!-- Page level plugins -->
<script src="/vendor/datatables/jquery.dataTables.min.js"></script>
<script src="/vendor/datatables/dataTables.bootstrap4.min.js"></script>

<script>
$(document).ready(function() {
    // Initialize DataTables
    $('#pagesTable, #blogTable').DataTable({
        "pageLength": 10,
        "order": [[2, "desc"]]
    });

    // Handle file upload
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');

    dropZone.addEventListener('click', () => fileInput.click());
    
    fileInput.addEventListener('change', handleFileSelect);
    
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(event => {
        dropZone.addEventListener(event, preventDefaults, false);
    });

    function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
    }
    
    function handleFileSelect(e) {
        const files = e.target.files || e.dataTransfer.files;
        if (files.length) {
            // Handle file upload
            console.log('Files selected:', files);
            // In a real app, you would upload the files here
        }
    }
});
</script>
