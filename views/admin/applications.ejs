<div class="applications-container">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>Manage Applications</h4>
            <div>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-filter me-1"></i> Filter
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item filter-option" href="?status=all" data-status="all">All Applications</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item filter-option" href="?status=pending" data-status="pending">
                            <span class="badge bg-warning me-2">●</span> Pending Review
                        </a></li>
                        <li><a class="dropdown-item filter-option" href="?status=under_review" data-status="under_review">
                            <span class="badge bg-info me-2">●</span> Under Review
                        </a></li>
                        <li><a class="dropdown-item filter-option" href="?status=accepted" data-status="accepted">
                            <span class="badge bg-success me-2">●</span> Approved
                        </a></li>
                        <li><a class="dropdown-item filter-option" href="?status=rejected" data-status="rejected">
                            <span class="badge bg-danger me-2">●</span> Rejected
                        </a></li>
                    </ul>
                </div>
                <button class="btn btn-primary ms-2" data-bs-toggle="modal" data-bs-target="#exportModal">
                    <i class="fas fa-download me-1"></i> Export
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="applicationsTable" class="table table-hover" style="width:100%">
                    <thead>
                        <tr>
                            <th>Sr. No.</th>
                            <th>ID</th>
                            <th>Business Name</th>
                            <th>Applicant</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Payment</th>
                            <th>Status</th>
                            <th>Submitted</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% let serialNumber = 1; %>
                        <% applications.forEach(application => { %>
                            <tr>
                                <td><%= serialNumber++ %></td>
                                <td>#<%= application.id %></td>
                                <td><%= application.business_name %></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-2">
                                            <div class="avatar-title bg-light rounded-circle text-primary">
                                                <%= application.user && application.user.name ? application.user.name.charAt(0).toUpperCase() : 'N' %>
                                            </div>
                                        </div>
                                        <div>
                                            <h6 class="mb-0"><%= application.user && application.user.name ? application.user.name : 'N/A' %></h6>
                                            <small class="text-muted"><%= application.user && application.user.email ? application.user.email : '' %></small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-<%= application.applicant_type === 'fresh_startup' ? 'info' : 'primary' %>">
                                        <%= application.applicant_type === 'fresh_startup' ? 'Startup' : 'Existing Business' %>
                                    </span>
                                </td>
                                <td>₹<%= application.amount_requested.toLocaleString('en-IN') %></td>
                                <td>
                                    <% const payStatus = application.payment_status ? String(application.payment_status) : 'pending'; %>
                                    <span class="badge bg-<%= payStatus === 'paid' || payStatus === 'captured' || payStatus === 'success' ? 'success' : (payStatus === 'failed' ? 'danger' : (payStatus === 'refunded' ? 'info' : 'secondary')) %>">
                                        <%= payStatus.toUpperCase() %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-<%= 
                                        application.application_status === 'accepted' ? 'success' : 
                                        application.application_status === 'rejected' ? 'danger' : 
                                        application.application_status === 'under_review' ? 'info' : 'warning' 
                                    %>">
                                        <%= application.application_status.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %>
                                    </span>
                                </td>
                                <td><% const d = application.createdAt || application.created_at; const dt = d ? new Date(d) : null; %><%= dt && !isNaN(dt) ? dt.toLocaleDateString() : '' %></td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="/admin/applications/<%= application.id %>" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                                            <span class="visually-hidden">Toggle Dropdown</span>
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li>
                                                <a class="dropdown-item" href="/admin/applications/<%= application.id %>/edit">
                                                    <i class="fas fa-edit me-2"></i>Edit
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#statusModal" 
                                                   data-app-id="<%= application.id %>" 
                                                   data-current-status="<%= application.application_status %>">
                                                    <i class="fas fa-exchange-alt me-2"></i>Change Status
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <a class="dropdown-item text-danger" href="#" data-bs-toggle="modal" data-bs-target="#deleteModal" data-app-id="<%= application.id %>">
                                                    <i class="fas fa-trash-alt me-2"></i>Delete
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Status Change Modal -->
<div class="modal fade" id="statusModal" tabindex="-1" aria-labelledby="statusModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="statusModalLabel">Update Application Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="statusForm" action="" method="POST">
                <div class="modal-body">
                    <input type="hidden" name="_method" value="PUT">
                    <div class="mb-3">
                        <label for="status" class="form-label">Status</label>
                        <select class="form-select" id="status" name="status" required>
                            <option value="pending">Pending</option>
                            <option value="under_review">Under Review</option>
                            <option value="accepted">Approved</option>
                            <option value="rejected">Rejected</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="admin_notes" class="form-label">Notes</label>
                        <textarea class="form-control" id="admin_notes" name="admin_notes" rows="3" placeholder="Add any notes or comments"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Status</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Deletion</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this application? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" action="" method="POST" class="d-inline">
                    <input type="hidden" name="_method" value="DELETE">
                    <button type="submit" class="btn btn-danger">Delete Application</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportModalLabel">Export Applications</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/admin/applications/export" method="GET">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="exportFormat" class="form-label">Format</label>
                        <select class="form-select" id="exportFormat" name="format" required>
                            <option value="csv">CSV</option>
                            <option value="excel">Excel</option>
                            <option value="pdf">PDF</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date Range</label>
                        <div class="row g-2">
                            <div class="col">
                                <input type="date" class="form-control" name="startDate" required>
                                <div class="form-text">Start Date</div>
                            </div>
                            <div class="col">
                                <input type="date" class="form-control" name="endDate" required>
                                <div class="form-text">End Date</div>
                            </div>
                        </div>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="includeAllFields" name="includeAllFields" checked>
                        <label class="form-check-label" for="includeAllFields">Include All Fields</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Export</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Initialize DataTable
document.addEventListener('DOMContentLoaded', function() {
    const table = $('#applicationsTable').DataTable({
        order: [[0, 'desc']], // Sort by ID descending by default
        pageLength: 25,
        responsive: true,
        language: {
            search: "_INPUT_",
            searchPlaceholder: "Search applications...",
            lengthMenu: "Show _MENU_ applications per page",
            zeroRecords: "No matching applications found",
            info: "Showing _START_ to _END_ of _TOTAL_ applications",
            infoEmpty: "No applications available",
            infoFiltered: "(filtered from _MAX_ total applications)"
        },
        dom: '<"d-flex justify-content-between align-items-center mb-3"f<"ms-3"l>>rt<"d-flex justify-content-between align-items-center"ip>',
        initComplete: function() {
            // Add custom filter dropdown
            $('.dataTables_filter').addClass('flex-grow-1');
        }
    });

    // Status modal handler
    const statusModal = document.getElementById('statusModal');
    if (statusModal) {
        statusModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            const appId = button.getAttribute('data-app-id');
            const currentStatus = button.getAttribute('data-current-status');
            
            const modalForm = statusModal.querySelector('form');
            modalForm.action = `/admin/applications/${appId}/status`;
            
            const statusSelect = statusModal.querySelector('#status');
            statusSelect.value = currentStatus;
        });
    }

    // Delete modal handler
    const deleteModal = document.getElementById('deleteModal');
    if (deleteModal) {
        deleteModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            const appId = button.getAttribute('data-app-id');
            
            const deleteForm = deleteModal.querySelector('form');
            deleteForm.action = `/admin/applications/${appId}`;
        });
    }

    // Filter buttons
    document.querySelectorAll('.filter-option').forEach(option => {
        option.addEventListener('click', function(e) {
            e.preventDefault();
            const status = this.getAttribute('data-status');
            
            if (status === 'all') {
                table.column(5).search('').draw();
            } else {
                table.column(5).search(status).draw();
            }
            
            // Update active state
            document.querySelectorAll('.filter-option').forEach(opt => {
                opt.classList.remove('active');
            });
            this.classList.add('active');
        });
    });

    // Set initial active filter based on URL
    const urlParams = new URLSearchParams(window.location.search);
    const statusParam = urlParams.get('status');
    if (statusParam) {
        const activeFilter = document.querySelector(`.filter-option[data-status="${statusParam}"]`);
        if (activeFilter) {
            activeFilter.click();
        }
    }
});
</script>
