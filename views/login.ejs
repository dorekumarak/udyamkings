<%- include('partials/header', { title: 'Login | UdyamKings' }) %>

<div class="auth-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <h2 class="mb-2">Welcome Back</h2>
                            <p class="text-muted">Sign in to your UdyamKings account</p>
                        </div>

                        <!-- Login Form -->
                        <form id="loginForm" action="/auth/login" method="POST" class="needs-validation" novalidate>
                            <div class="mb-3">
                                <label for="email" class="form-label">Email Address <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                    <input type="email" class="form-control" id="email" name="email" required>
                                </div>
                                <div class="invalid-feedback">Please enter your registered email address.</div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary py-2">
                                    <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                                    <span class="btn-text">Send OTP to Email</span>
                                </button>
                            </div>
                        </form>
                        
                        <!-- OTP Verification (initially hidden) -->
                        <form id="otpForm" action="/auth/verify-otp" method="POST" class="d-none needs-validation" novalidate>
                            <p class="text-muted mb-3">We've sent a 6-digit OTP to <span id="userEmail" class="fw-bold"></span></p>
                            
                            <div class="otp-inputs mb-3">
                                <div class="row g-2">
                                    <% for(let i = 0; i < 6; i++) { %>
                                        <div class="col-2">
                                            <input type="text" 
                                                   class="form-control form-control-lg text-center otp-digit" 
                                                   maxlength="1" 
                                                   pattern="[0-9]"
                                                   data-index="<%= i %>"
                                                   required>
                                        </div>
                                    <% } %>
                                    <input type="hidden" name="otp" id="otp">
                                </div>
                                <div class="invalid-feedback">Please enter the 6-digit OTP sent to your email.</div>
                            </div>
                            
                            <div class="text-center mb-3">
                                <button type="button" id="resendOtp" class="btn btn-link p-0">Resend OTP</button>
                                <div id="resendTimer" class="small text-muted">Resend OTP in <span id="countdown">60</span>s</div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary py-2">
                                    <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                                    <span class="btn-text">Verify & Continue</span>
                                </button>
                                
                                <button type="button" id="backToLogin" class="btn btn-outline-secondary mt-2">
                                    <i class="fas fa-arrow-left me-1"></i> Back to Login
                                </button>
                            </div>
                        </form>
                        
                        <div class="text-center mt-4">
                            <p class="mb-0">Don't have an account? <a href="/register">Sign Up</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const loginForm = document.getElementById('loginForm');
    const otpForm = document.getElementById('otpForm');
    const userEmailSpan = document.getElementById('userEmail');
    const otpInputs = document.querySelectorAll('.otp-digit');
    const otpHiddenInput = document.getElementById('otp');
    const resendOtpBtn = document.getElementById('resendOtp');
    const resendTimer = document.getElementById('resendTimer');
    const backToLoginBtn = document.getElementById('backToLogin');
    
    let countdown;
    let timeLeft = 60;
    
    // Handle login form submission
    loginForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        if (!this.checkValidity()) {
            e.stopPropagation();
            this.classList.add('was-validated');
            return;
        }
        
        const submitBtn = this.querySelector('button[type="submit"]');
        const spinner = submitBtn.querySelector('.spinner-border');
        const btnText = submitBtn.querySelector('.btn-text');
        
        // Show loading state
        submitBtn.disabled = true;
        spinner.classList.remove('d-none');
        btnText.textContent = 'Sending OTP...';
        
        try {
            const formData = new FormData(this);
            
            // API call to send OTP
            const response = await fetch('/auth/send-otp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    email: formData.get('email')
                })
            });
            
            const data = await response.json();
            
            if (data.success) {
                // Show OTP form
                userEmailSpan.textContent = formData.get('email');
                loginForm.classList.add('d-none');
                otpForm.classList.remove('d-none');
                
                // Focus first OTP input
                if (otpInputs.length > 0) {
                    otpInputs[0].focus();
                }
                
                // Start resend timer
                startResendTimer();
                
                // Show success message
                showAlert('success', 'OTP has been sent to your email address.');
            } else {
                showAlert('danger', data.message || 'Failed to send OTP. Please try again.');
            }
        } catch (error) {
            console.error('Error:', error);
            showAlert('danger', 'An error occurred. Please try again later.');
        } finally {
            // Reset button state
            submitBtn.disabled = false;
            spinner.classList.add('d-none');
            btnText.textContent = 'Send OTP to Email';
        }
    });
    
    // Handle OTP input
    otpInputs.forEach((input, index) => {
        input.addEventListener('input', function() {
            // Allow only numbers
            this.value = this.value.replace(/[^0-9]/g, '');
            
            // Move to next input on number input
            if (this.value.length === 1 && index < otpInputs.length - 1) {
                otpInputs[index + 1].focus();
            }
            
            // Update hidden input
            updateOtpValue();
        });
        
        // Handle backspace
        input.addEventListener('keydown', function(e) {
            if (e.key === 'Backspace' && this.value === '' && index > 0) {
                otpInputs[index - 1].focus();
            }
        });
    });
    
    // Update hidden OTP value
    function updateOtpValue() {
        let otp = '';
        otpInputs.forEach(input => {
            otp += input.value;
        });
        otpHiddenInput.value = otp;
    }
    
    // Handle OTP form submission
    otpForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        if (!this.checkValidity()) {
            e.stopPropagation();
            this.classList.add('was-validated');
            return;
        }
        
        const submitBtn = this.querySelector('button[type="submit"]');
        const spinner = submitBtn.querySelector('.spinner-border');
        const btnText = submitBtn.querySelector('.btn-text');
        
        // Show loading state
        submitBtn.disabled = true;
        spinner.classList.remove('d-none');
        btnText.textContent = 'Verifying...';
        
        try {
            const formData = new FormData(this);
            const email = userEmailSpan.textContent;
            
            // API call to verify OTP
            const response = await fetch('/auth/verify-otp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    email: email,
                    otp: formData.get('otp')
                })
            });
            
            const data = await response.json();
            
            if (data.success) {
                // Redirect to dashboard or intended URL
                const redirectUrl = new URLSearchParams(window.location.search).get('redirect') || '/dashboard';
                window.location.href = redirectUrl;
            } else {
                showAlert('danger', data.message || 'Invalid OTP. Please try again.');
            }
        } catch (error) {
            console.error('Error:', error);
            showAlert('danger', 'An error occurred. Please try again later.');
        } finally {
            // Reset button state
            submitBtn.disabled = false;
            spinner.classList.add('d-none');
            btnText.textContent = 'Verify & Continue';
        }
    });
    
    // Handle resend OTP
    resendOtpBtn.addEventListener('click', async function() {
        const email = userEmailSpan.textContent;
        
        if (!email) return;
        
        // Disable resend button and show loading
        this.disabled = true;
        const originalText = this.textContent;
        this.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Sending...';
        
        try {
            // API call to resend OTP
            const response = await fetch('/auth/resend-otp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ email: email })
            });
            
            const data = await response.json();
            
            if (data.success) {
                // Reset OTP inputs
                otpInputs.forEach(input => {
                    input.value = '';
                    input.classList.remove('is-invalid');
                });
                otpInputs[0].focus();
                updateOtpValue();
                
                // Reset and restart timer
                clearInterval(countdown);
                timeLeft = 60;
                startResendTimer();
                
                showAlert('success', 'A new OTP has been sent to your email.');
            } else {
                showAlert('danger', data.message || 'Failed to resend OTP. Please try again.');
            }
        } catch (error) {
            console.error('Error:', error);
            showAlert('danger', 'An error occurred. Please try again later.');
        } finally {
            // Reset button state
            this.disabled = false;
            this.textContent = originalText;
        }
    });
    
    // Back to login form
    backToLoginBtn.addEventListener('click', function() {
        loginForm.classList.remove('d-none');
        otpForm.classList.add('d-none');
        clearInterval(countdown);
    });
    
    // Start resend OTP timer
    function startResendTimer() {
        resendOtpBtn.style.display = 'none';
        resendTimer.style.display = 'block';
        document.getElementById('countdown').textContent = timeLeft;
        
        countdown = setInterval(() => {
            timeLeft--;
            document.getElementById('countdown').textContent = timeLeft;
            
            if (timeLeft <= 0) {
                clearInterval(countdown);
                resendOtpBtn.style.display = 'inline';
                resendTimer.style.display = 'none';
                timeLeft = 60;
            }
        }, 1000);
    }
    
    // Show alert message
    function showAlert(type, message) {
        // Remove any existing alerts
        const existingAlerts = document.querySelectorAll('.alert');
        existingAlerts.forEach(alert => alert.remove());
        
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show mt-3`;
        alertDiv.role = 'alert';
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        `;
        
        const cardBody = document.querySelector('.card-body');
        cardBody.insertBefore(alertDiv, cardBody.firstChild);
        
        // Auto-dismiss after 5 seconds
        setTimeout(() => {
            const bsAlert = new bootstrap.Alert(alertDiv);
            bsAlert.close();
        }, 5000);
    }
    
    // Show error/success messages from URL parameters
    const urlParams = new URLSearchParams(window.location.search);
    const status = urlParams.get('status');
    const message = urlParams.get('message');
    
    if (status === 'success' && message) {
        showAlert('success', decodeURIComponent(message));
    } else if (status === 'error' && message) {
        showAlert('danger', decodeURIComponent(message));
    }
});
</script>
