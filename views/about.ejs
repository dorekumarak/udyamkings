<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About | UdyamKings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/font-awesome.css">
    <style>
        body {
            background-color: #0A2463;
            min-height: 100vh;
            font-family: 'Poppins', sans-serif;
        }
        .about-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            margin: 100px auto;
            max-width: 1000px;
            overflow: hidden;
        }
        .about-header {
            background: linear-gradient(135deg, #0A2463, #051336);
            color: white;
            padding: 3rem 2rem;
            text-align: center;
        }
        .about-body {
            padding: 3rem;
        }
        .mission-card {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 2rem;
            margin-bottom: 2rem;
            border-left: 4px solid #0A2463;
        }
        .team-card {
            background: white;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            padding: 1.5rem;
            text-align: center;
            margin-bottom: 2rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .team-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        .team-img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            margin: 0 auto 1rem;
            background: linear-gradient(135deg, #0A2463, #051336);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 2rem;
        }
        .nav-link {
            color: white !important;
            text-decoration: none;
            padding: 0.5rem 1rem;
            transition: all 0.3s ease;
        }
        .nav-link:hover {
            color: #FFD700 !important;
        }
        .nav-link.active {
            color: #FFD700 !important;
        }
        .navbar {
            background: #0A2463 !important;
            padding: 1rem 0;
        }
        .navbar-brand {
            color: white !important;
            font-weight: 800;
            font-size: 1.5rem;
        }
        .values-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }
        .value-item {
            text-align: center;
            padding: 1.5rem;
        }
        .value-icon {
            font-size: 3rem;
            color: #0A2463;
            margin-bottom: 1rem;
        }
        .timeline {
            position: relative;
            padding: 2rem 0;
        }
        .timeline::before {
            content: '';
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #0A2463;
        }
        .timeline-item {
            position: relative;
            margin: 2rem 0;
        }
        .timeline-content {
            background: #f8f9fa;
            padding: 1.5rem;
            border-radius: 8px;
            width: 45%;
        }
        .timeline-item:nth-child(odd) .timeline-content {
            margin-left: auto;
        }
        .timeline-dot {
            position: absolute;
            left: 50%;
            top: 2rem;
            width: 20px;
            height: 20px;
            background: #FFD700;
            border: 3px solid #0A2463;
            border-radius: 50%;
            transform: translateX(-50%);
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">UdyamKings</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/">Home</a>
                <a class="nav-link active" href="/about">About</a>
                <a class="nav-link" href="/contact">Contact</a>
                <a class="nav-link" href="/login">Login</a>
                <a class="nav-link" href="/register">Register</a>
                <a class="nav-link" href="/admin/login">Admin</a>
                <a class="nav-link btn btn-warning text-dark px-3" href="/apply">Apply Now</a>
            </div>
        </div>
    </nav>

    <!-- About Content -->
    <div class="container">
        <div class="about-container">
            <div class="about-header">
                <h1><i class="fas fa-crown me-2"></i>About UdyamKings</h1>
                <p class="lead">Turning Ambition Into Empires Since 2020</p>
            </div>
            <div class="about-body">
                <!-- Mission Section -->
                <div class="mission-card">
                    <h3><i class="fas fa-bullseye me-2"></i>Our Mission</h3>
                    <p>To empower ambitious entrepreneurs with the capital, mentorship, and resources they need to transform their innovative ideas into successful businesses that create lasting impact.</p>
                </div>

                <!-- Vision Section -->
                <div class="mission-card">
                    <h3><i class="fas fa-eye me-2"></i>Our Vision</h3>
                    <p>To be the leading catalyst for entrepreneurial success in India, fostering a new generation of business leaders who drive economic growth and social change.</p>
                </div>

                <!-- Values Section -->
                <h3 class="text-center mb-4">Our Core Values</h3>
                <div class="values-grid">
                    <div class="value-item">
                        <div class="value-icon">
                            <i class="fas fa-handshake"></i>
                        </div>
                        <h5>Integrity</h5>
                        <p>We conduct business with honesty and transparency</p>
                    </div>
                    <div class="value-item">
                        <div class="value-icon">
                            <i class="fas fa-lightbulb"></i>
                        </div>
                        <h5>Innovation</h5>
                        <p>We foster creativity and forward-thinking solutions</p>
                    </div>
                    <div class="value-item">
                        <div class="value-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <h5>Collaboration</h5>
                        <p>We believe in the power of partnerships</p>
                    </div>
                    <div class="value-item">
                        <div class="value-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <h5>Growth</h5>
                        <p>We are committed to continuous improvement</p>
                    </div>
                </div>

                <!-- Stats Section -->
                <div class="row text-center my-5">
                    <div class="col-md-3">
                        <h2 class="text-primary">500+</h2>
                        <p>Startups Funded</p>
                    </div>
                    <div class="col-md-3">
                        <h2 class="text-primary">₹100Cr+</h2>
                        <p>Funds Disbursed</p>
                    </div>
                    <div class="col-md-3">
                        <h2 class="text-primary">50+</h2>
                        <p>Industry Experts</p>
                    </div>
                    <div class="col-md-3">
                        <h2 class="text-primary">95%</h2>
                        <p>Success Rate</p>
                    </div>
                </div>

                <!-- Timeline Section -->
                <h3 class="text-center mb-4">Our Journey</h3>
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h5>2020</h5>
                            <p>UdyamKings founded with a vision to support Indian entrepreneurs</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h5>2021</h5>
                            <p>Launched first funding program, supported 50 startups</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h5>2022</h5>
                            <p>Expanded to multiple cities, partnered with leading incubators</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h5>2023</h5>
                            <p>Reached ₹100Cr+ in funding disbursed milestone</p>
                        </div>
                    </div>
                </div>

                <!-- Team Section -->
                <h3 class="text-center mb-4">Leadership Team</h3>
                <div class="row">
                    <div class="col-md-4">
                        <div class="team-card">
                            <div class="team-img">
                                <i class="fas fa-user"></i>
                            </div>
                            <h5>Raj Sharma</h5>
                            <p class="text-muted">Founder & CEO</p>
                            <p>20+ years in venture capital and startup mentoring</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="team-card">
                            <div class="team-img">
                                <i class="fas fa-user"></i>
                            </div>
                            <h5>Priya Patel</h5>
                            <p class="text-muted">COO</p>
                            <p>Expert in operations and scaling businesses</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="team-card">
                            <div class="team-img">
                                <i class="fas fa-user"></i>
                            </div>
                            <h5>Amit Kumar</h5>
                            <p class="text-muted">CFO</p>
                            <p>Financial strategist with 15+ years experience</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
