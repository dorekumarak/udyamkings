<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Apply for Funding | UdyamKings</title>

    <link href="/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/font-awesome.css">

    <style>

        body {

            background-color: #0A2463;

            min-height: 100vh;

            font-family: 'Poppins', sans-serif;

        }

        .apply-container {

            background: white;

            border-radius: 12px;

            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);

            margin: 80px auto;

            max-width: 1000px;

            overflow: hidden;

        }

        .apply-header {

            background: linear-gradient(135deg, #0A2463, #051336);

            color: white;

            padding: 2rem;

            text-align: center;

        }

        .apply-header h1,

        .apply-header p {

            color: #ffffff !important;

        }

        .apply-body {

            padding: 3rem;

        }

        .progress-bar-container {

            margin-bottom: 3rem;

            width: 100%;

            max-width: 100%;

            text-align: left;

        }

        .progress-step {

            display: flex;

            align-items: flex-start;

            margin-bottom: 1rem;

            gap: 1rem;

        }

        .progress-step > div:last-child {

            flex: 1;

            text-align: left;

            line-height: 40px;

        }

        .step-number {

            width: 40px;

            height: 40px;

            border-radius: 50%;

            background: #0A2463 !important;

            border: 2px solid #0A2463 !important;

            display: flex;

            align-items: center;

            justify-content: center;

            font-weight: bold;

            flex: 0 0 40px;

            color: #fff !important;

        }

        .step-number.active {

            background: #0A2463 !important;

            color: #fff !important;

        }

        .step-number.completed {

            background: #0A2463 !important;

            color: #fff !important;

        }

        .form-section {

            display: none;

        }

        .form-section.active {

            display: block;

        }

        .btn-apply {

            background: linear-gradient(135deg, #0A2463, #051336);

            border: none;

            color: #fff;

            padding: 0.75rem 2rem;

            font-weight: 600;

            border-radius: 8px;

            transition: all 0.3s ease;

        }

        .btn-apply:hover {

            transform: translateY(-2px);

            box-shadow: 0 5px 15px rgba(10, 36, 99, 0.3);

        }

        .nav-link {

            color: white !important;

            text-decoration: none;

            padding: 0.5rem 1rem;

            transition: all 0.3s ease;

        }

        .nav-link:hover {

            color: #FFD700 !important;

        }

        .nav-link.active {

            color: #FFD700 !important;

        }

        .navbar {

            background: #0A2463 !important;

            padding: 1rem 0;

        }

        .navbar-brand {

            color: white !important;

            font-weight: 800;

            font-size: 1.5rem;

        }

        .form-control:focus {

            border-color: #0A2463;

            box-shadow: 0 0 0 0.2rem rgba(10, 36, 99, 0.25);

        }

        .required {

            color: #dc3545;

        }

        .form-control {

            border: 1px solid #000000 !important;

        }

    </style>

</head>

<body>

<!-- Navigation -->

<nav class="navbar navbar-expand-lg navbar-dark">

    <div class="container">

        <a class="navbar-brand" href="/">UdyamKings</a>

        <div class="navbar-nav ms-auto">

            <a class="nav-link" href="/">Home</a>

            <a class="nav-link" href="/about">About</a>

            <a class="nav-link" href="/contact">Contact</a>

            <a class="nav-link" href="/login">Login</a>

            <a class="nav-link" href="/register">Register</a>

            <a class="nav-link" href="/admin/login">Admin</a>

            <a class="nav-link btn btn-warning text-dark px-3" href="/apply">Apply Now</a>

        </div>

    </div>

</nav>



<!-- Apply Content -->

<div class="container">

    <div class="apply-container">

        <div class="apply-header">

            <h1><i class="fas fa-rocket me-2"></i><%= (typeof draftApplication !== 'undefined' && draftApplication) ? 'Continue Application' : 'Apply for Funding' %></h1>

            <p class="lead">Take the first step towards turning your ambition into an empire</p>

        </div>

        <div class="apply-body">

                <% if (messages.success_msg && messages.success_msg.length > 0) { %>

                    <% messages.success_msg.forEach(function(message) { %>

                        <div class="alert alert-success">

                            <%= message %>

                        </div>

                    <% }); %>

                <% } %>



                <% if (messages.error_msg && messages.error_msg.length > 0) { %>

                    <% messages.error_msg.forEach(function(message) { %>

                        <div class="alert alert-danger">

                            <%= message %>

                        </div>

                    <% }); %>

                <% } %>



                <!-- Progress Bar -->

                <div class="progress-bar-container">

                    <h4 class="mb-3">Application Progress</h4>

                    <div class="progress-step">

                        <div class="step-number active" id="step1">1</div>

                        <div>Personal Information</div>

                    </div>

                    <div class="progress-step">

                        <div class="step-number" id="step2">2</div>

                        <div>Business Details</div>

                    </div>

                    <div class="progress-step">

                        <div class="step-number" id="step3">3</div>

                        <div>Funding Requirements</div>

                    </div>

                    <div class="progress-step">

                        <div class="step-number" id="step4">4</div>

                        <div>Documents Upload</div>

                    </div>

                    <div class="progress-step">

                        <div class="step-number" id="step5">5</div>

                        <div>Review & Submit</div>

                    </div>

                </div>



                <form action="/apply" method="POST" id="applicationForm" novalidate>

                    <!-- Step 1: Personal Information -->

                    <div class="form-section active" id="section1">

                        <h4 class="mb-4">Personal Information</h4>

                        <div class="row">

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Full Name <span class="required">*</span></label>

                                    <input type="text" class="form-control" name="fullName" value="<%= user ? user.name : '' %>" required>

                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Email Address <span class="required">*</span></label>

                                    <input type="email" class="form-control" name="email" value="<%= user ? user.email : '' %>" required>

                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Phone Number <span class="required">*</span></label>

                                    <input type="tel" class="form-control" name="phone" value="<%= user ? user.mobile : '' %>" required>

                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Date of Birth <span class="required">*</span></label>

                                    <input type="date" class="form-control" name="dob" required>

                                </div>

                            </div>

                            <div class="col-12">

                                <div class="mb-3">

                                    <label class="form-label">Address <span class="required">*</span></label>

                                    <textarea class="form-control" name="address" rows="3" required></textarea>

                                </div>

                            </div>

                        </div>

                        <button type="button" class="btn btn-apply float-end" onclick="nextStep(1)">Next Step <i class="fas fa-arrow-right ms-2"></i></button>

                    </div>



                    <!-- Step 2: Business Details -->

                    <div class="form-section" id="section2">

                        <h4 class="mb-4">Business Details</h4>

                        <div class="row">

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Business Name <span class="required">*</span></label>

                                    <input type="text" class="form-control" name="businessName" value="<%= (typeof draftApplication !== 'undefined' && draftApplication) ? draftApplication.business_name : '' %>" required>

                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Industry <span class="required">*</span></label>

                                    <select class="form-control" name="industry" required>

                                        <option value="">Select Industry</option>

                                        <option value="technology">Technology</option>

                                        <option value="healthcare">Healthcare</option>

                                        <option value="education">Education</option>

                                        <option value="retail">Retail</option>

                                        <option value="manufacturing">Manufacturing</option>

                                        <option value="services">Services</option>

                                        <option value="other">Other</option>

                                    </select>

                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Business Type <span class="required">*</span></label>

                                    <select class="form-control" name="businessType" required>

                                        <option value="">Select Type</option>

                                        <option value="startup" <%= (typeof draftApplication !== 'undefined' && draftApplication) && draftApplication.applicant_type === 'fresh_startup' ? 'selected' : '' %>>Startup</option>

                                        <option value="existing" <%= draftApplication && draftApplication.applicant_type === 'existing_business' ? 'selected' : '' %>>Existing Business</option>

                                        <option value="expansion">Business Expansion</option>

                                    </select>

                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Years in Operation</label>

                                    <input type="number" class="form-control" name="yearsInOperation" min="0">

                                </div>

                            </div>

                            <div class="col-12">

                                <div class="mb-3">

                                    <label class="form-label">Business Description <span class="required">*</span></label>

                                    <textarea class="form-control" name="businessDescription" rows="4" required><%= draftApplication ? draftApplication.description_short : '' %></textarea>

                                </div>

                            </div>

                        </div>

                        <button type="button" class="btn btn-secondary me-2" onclick="prevStep(2)"><i class="fas fa-arrow-left me-2"></i> Previous</button>

                        <button type="button" class="btn btn-apply float-end" onclick="nextStep(2)">Next Step <i class="fas fa-arrow-right ms-2"></i></button>

                    </div>



                    <!-- Step 3: Funding Requirements -->

                    <div class="form-section" id="section3">

                        <h4 class="mb-4">Funding Requirements</h4>

                        <div class="row">

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Funding Amount Required <span class="required">*</span></label>

                                    <input type="number" class="form-control" name="fundingAmount" min="0" value="<%= draftApplication ? draftApplication.amount_requested : '' %>" required>

                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label class="form-label">Funding Purpose <span class="required">*</span></label>

                                    <select class="form-control" name="fundingPurpose" required>

                                        <option value="">Select Purpose</option>

                                        <option value="working-capital">Working Capital</option>

                                        <option value="expansion">Business Expansion</option>

                                        <option value="equipment">Equipment Purchase</option>

                                        <option value="marketing">Marketing & Sales</option>

                                        <option value="inventory">Inventory</option>

                                        <option value="other">Other</option>

                                    </select>

                                </div>

                            </div>

                            <div class="col-12">

                                <div class="mb-3">

                                    <label class="form-label">Use of Funds <span class="required">*</span></label>

                                    <textarea class="form-control" name="useOfFunds" rows="4" required placeholder="Please describe how you plan to use the funds"><%= draftApplication ? draftApplication.description_long : '' %></textarea>

                                </div>

                            </div>

                            <div class="col-12">

                                <div class="mb-3">

                                    <label class="form-label">Expected ROI</label>

                                    <input type="text" class="form-control" name="expectedROI" placeholder="e.g., 25% in 2 years">

                                </div>

                            </div>

                            <div class="col-12">

                                <div class="mb-3">

                                    <label class="form-label">Preferred Contact Time <span class="required">*</span></label>

                                    <select class="form-control" name="preferredContactTime" required>

                                        <option value="">Select Time</option>

                                        <option value="morning">Morning (9AM - 12PM)</option>

                                        <option value="afternoon">Afternoon (12PM - 5PM)</option>

                                        <option value="evening">Evening (5PM - 8PM)</option>

                                    </select>

                                </div>

                            </div>

                        </div>

                        <button type="button" class="btn btn-secondary me-2" onclick="prevStep(3)"><i class="fas fa-arrow-left me-2"></i> Previous</button>

                        <button type="button" class="btn btn-apply float-end" onclick="nextStep(3)">Next Step <i class="fas fa-arrow-right ms-2"></i></button>

                    </div>



                    <!-- Step 4: Documents Upload -->

                    <div class="form-section" id="section4">

                        <h4 class="mb-4">Documents Upload</h4>

                        <div class="row">

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Aadhaar Card <span class="required">*</span></label>
                                    <input type="file" class="form-control" name="idProof" accept=".pdf,.jpg,.jpeg,.png" required>
                                    <small class="text-muted">PDF, JPG, PNG (Max 2MB)</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">PAN Card <span class="required">*</span></label>
                                    <input type="file" class="form-control" name="addressProof" accept=".pdf,.jpg,.jpeg,.png" required>
                                    <small class="text-muted">PDF, JPG, PNG (Max 2MB)</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Business Plan (optional)</label>
                                    <input type="file" class="form-control" name="businessPlan" accept=".pdf,.doc,.docx">
                                    <small class="text-muted">PDF, DOC, DOCX (Max 5MB)</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Supporting Documents (optional)</label>
                                    <input type="file" class="form-control" name="financialProjections" accept=".pdf,.xls,.xlsx" title="supporting documents like if the existing business gst and bank statements, and business related documents">
                                    <small class="text-muted">PDF, XLS, XLSX (Max 5MB)</small>
                                </div>
                            </div>

                        </div>

                        <button type="button" class="btn btn-secondary me-2" onclick="prevStep(4)"><i class="fas fa-arrow-left me-2"></i> Previous</button>

                        <button type="button" class="btn btn-apply float-end" onclick="nextStep(4)">Next Step <i class="fas fa-arrow-right ms-2"></i></button>

                    </div>



                    <!-- Step 5: Review & Submit -->

                    <div class="form-section" id="section5">

                        <h4 class="mb-4">Review & Submit</h4>

                        <div class="alert alert-info">

                            <h5><i class="fas fa-info-circle me-2"></i>Application Review</h5>

                            <p>Please review all the information you've provided before submitting your application. Once submitted, you will receive a confirmation email with your application reference number.</p>

                        </div>



                        <div id="applyAlert" class="alert" style="display:none;"></div>

                        

                        <div class="mb-3">

                            <div class="form-check">

                                <input class="form-check-input" type="checkbox" id="terms" name="terms" required>

                                <label class="form-check-label" for="terms">

                                    I agree to the <a href="#" data-bs-toggle="modal" data-bs-target="#termsModal">Terms and Conditions</a> and <a href="#" data-bs-toggle="modal" data-bs-target="#privacyModal">Privacy Policy</a> <span class="required">*</span>

                                </label>

                            </div>

                        </div>

                        

                        <div class="mb-3">

                            <div class="form-check">

                                <input class="form-check-input" type="checkbox" id="declaration" name="declaration" required>

                                <label class="form-check-label" for="declaration">

                                    I declare that all information provided is true and accurate to the best of my knowledge <span class="required">*</span>

                                </label>

                            </div>

                        </div>

                        

                        <button type="button" class="btn btn-secondary me-2" onclick="prevStep(5)"><i class="fas fa-arrow-left me-2"></i> Previous</button>

                        <button type="submit" class="btn btn-success float-end"><i class="fas fa-check me-2"></i> Submit Application</button>

                    </div>

                </form>

            </div>

        </div>

    </div>



    <!-- Terms Modal -->

    <div class="modal fade" id="termsModal" tabindex="-1">

        <div class="modal-dialog modal-lg">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">Terms and Conditions</h5>

                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">

                    <h6>1. Eligibility</h6>

                    <p>Applicants must be Indian citizens aged 18 years or above with a valid business registration or proposal.</p>

                    

                    <h6>2. Application Process</h6>

                    <p>All applications are subject to review and verification. UdyamKings reserves the right to reject any application without providing reasons.</p>

                    

                    <h6>3. Funding Terms</h6>

                    <p>Funding terms and conditions will be communicated separately based on the application evaluation and business requirements.</p>

                    

                    <h6>4. Confidentiality</h6>

                    <p>All information provided will be kept confidential and used solely for evaluation purposes.</p>

                </div>

                <div class="modal-footer">

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>

                </div>

            </div>

        </div>

    </div>



    <!-- Privacy Modal -->

    <div class="modal fade" id="privacyModal" tabindex="-1">

        <div class="modal-dialog modal-lg">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">Privacy Policy</h5>

                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">

                    <h6>1. Information Collection</h6>

                    <p>We collect personal and business information necessary for evaluating funding applications.</p>

                    

                    <h6>2. Information Usage</h6>

                    <p>Your information is used solely for application processing, communication, and improving our services.</p>

                    

                    <h6>3. Data Security</h6>

                    <p>We implement appropriate security measures to protect your personal information from unauthorized access.</p>

                    

                    <h6>4. Information Sharing</h6>

                    <p>We do not sell, trade, or otherwise transfer your personal information to third parties without your consent.</p>

                </div>

                <div class="modal-footer">

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>

                </div>

            </div>

        </div>

    </div>



    <script src="/js/bootstrap.bundle.min.js"></script>

    <script>

        let currentStep = 1;

        const totalSteps = 5;



        function shouldRequireDocuments() {

            const businessType = document.querySelector('select[name="businessType"]')?.value;

            return businessType === 'existing' || businessType === 'expansion';

        }



        function initOriginalRequiredFlags() {

            const form = document.getElementById('applicationForm');

            if (!form) return;



            form.querySelectorAll('input, select, textarea').forEach((el) => {

                if (el.hasAttribute('required')) {

                    el.dataset.origRequired = '1';

                }

            });

        }



        function updateRequiredForStep(step) {

            const form = document.getElementById('applicationForm');

            if (!form) return;



            // Remove required from everything first so hidden steps never block

            form.querySelectorAll('input, select, textarea').forEach((el) => {

                el.removeAttribute('required');

            });



            const section = document.getElementById('section' + step);

            if (!section) return;



            const requireDocs = shouldRequireDocuments();



            // Re-apply required only for fields in the active step that were originally required

            section.querySelectorAll('input, select, textarea').forEach((el) => {

                const wasRequired = el.dataset.origRequired === '1';

                if (!wasRequired) return;



                if (el.type === 'file') {

                    // Documents required only for existing/expansion

                    if (requireDocs) el.setAttribute('required', 'required');

                    return;

                }



                el.setAttribute('required', 'required');

            });

        }



        function validateCurrentStep() {

            const section = document.getElementById('section' + currentStep);

            if (!section) return true;



            // Evaluate validity only for the currently visible step

            const fields = Array.from(section.querySelectorAll('input, select, textarea'));

            for (const el of fields) {

                // Skip disabled/hidden within the step

                if (el.disabled) continue;



                const isValid = el.checkValidity();

                if (!isValid) {

                    try { el.focus(); } catch (_) {}

                    el.reportValidity();

                    return false;

                }

            }

            return true;

        }



        function showStep(step) {

            // Hide all sections

            document.querySelectorAll('.form-section').forEach(section => {

                section.classList.remove('active');

            });

            

            // Show current section

            document.getElementById('section' + step).classList.add('active');



            updateRequiredForStep(step);

            

            // Update progress indicators

            for (let i = 1; i <= totalSteps; i++) {

                const stepElement = document.getElementById('step' + i);

                stepElement.classList.remove('active', 'completed');

                

                if (i < step) {

                    stepElement.classList.add('completed');

                    stepElement.innerHTML = '<i class="fas fa-check"></i>';

                } else if (i === step) {

                    stepElement.classList.add('active');

                    stepElement.innerHTML = i;

                } else {

                    stepElement.innerHTML = i;

                }

            }

        }



        function nextStep(step) {

            if (step < totalSteps) {

                currentStep = step;

                updateRequiredForStep(currentStep);

                if (!validateCurrentStep()) {

                    return;

                }

                currentStep = step + 1;

                showStep(currentStep);

                

                // Scroll to top

                window.scrollTo({ top: 0, behavior: 'smooth' });

            }

        }



        function prevStep(step) {

            if (step > 1) {

                currentStep = step - 1;

                showStep(currentStep);

                

                // Scroll to top

                window.scrollTo({ top: 0, behavior: 'smooth' });

            }

        }



        // Form submission

        document.getElementById('applicationForm').addEventListener('submit', async function(e) {

            e.preventDefault();



            const form = e.target;

            const alertEl = document.getElementById('applyAlert');

            const submitBtn = form.querySelector('button[type="submit"]');



            console.log('Submitting application form...');



            alertEl.style.display = 'none';

            alertEl.className = 'alert';

            alertEl.textContent = '';



            updateRequiredForStep(currentStep);

            if (!validateCurrentStep()) {

                return;

            }



            // Use FormData instead of JSON for file uploads

            const formData = new FormData(form);

            

            // Map form field names to controller expected names

            const fieldMappings = {

                'businessType': 'applicantType',

                'businessDescription': 'shortDescription', 

                'useOfFunds': 'detailedPlan',

                'fundingAmount': 'amountRequested',

                'fundingPurpose': 'fundUsage'

            };

            

            // Rename form fields to match controller expectations

            for (const [key, value] of Array.from(formData.entries())) {

                if (fieldMappings[key]) {

                    formData.set(fieldMappings[key], value);

                    formData.delete(key);

                }

            }

            

            // Remove file entries and add them back with correct names for multer

            const fileInputs = form.querySelectorAll('input[type="file"]');

            console.log('Found file inputs:', fileInputs.length);

            fileInputs.forEach(input => {

                console.log('File input:', input.name, 'files:', input.files.length);

                const files = input.files;

                for (let i = 0; i < files.length; i++) {

                    // Map form field names to multer expected names

                    let fieldName = input.name;

                    if (fieldName === 'idProof') fieldName = 'aadharFile';

                    if (fieldName === 'addressProof') fieldName = 'gstFile';

                    if (fieldName === 'businessPlan') fieldName = 'registrationFile';

                    if (fieldName === 'financialProjections') fieldName = 'financialFile';

                    

                    console.log('Appending file:', fieldName, files[i].name);

                    formData.append(fieldName, files[i]);

                }

                // Remove original file entries

                formData.delete(input.name);

            });



            submitBtn.disabled = true;

            const originalHtml = submitBtn.innerHTML;

            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Submitting...';



            try {

                console.log('Submitting application form...');

                const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

                console.log('CSRF Token:', csrfToken);

                console.log('FormData entries:');

                for (let [key, value] of formData.entries()) {

                    console.log(key, value);

                }

                

                const resp = await fetch('/apply', {

                    method: 'POST',

                    credentials: 'same-origin',

                    headers: {

                        ...(csrfToken ? { 'CSRF-Token': csrfToken } : {})

                    },

                    body: formData

                });



                console.log('Response status:', resp.status);

                console.log('Response ok:', resp.ok);



                const rawText = await resp.text();

                console.log('Raw response:', rawText);

                

                let data = {};

                try {

                    data = rawText ? JSON.parse(rawText) : {};

                } catch (parseErr) {

                    console.error('Parse error:', parseErr);

                    data = { success: false, message: rawText || 'Unexpected non-JSON response from server.' };

                }



                console.log('Parsed data:', data);



                if (!resp.ok || !data.success) {

                    alertEl.textContent = data.message || 'Submission failed. Please try again.';

                    alertEl.className = 'alert alert-danger';

                    alertEl.style.display = 'block';

                    submitBtn.disabled = false;

                    submitBtn.innerHTML = originalHtml;

                    return;

                }



                alertEl.textContent = data.message || 'Application submitted successfully';

                alertEl.className = 'alert alert-success';

                alertEl.style.display = 'block';

                submitBtn.innerHTML = '<i class="fas fa-check me-2"></i>Submitted';



                // Redirect to static payment page after 2 seconds

                setTimeout(() => {

                    window.location.href = '/payment.html';

                }, 2000);

            } catch (err) {

                console.error('Application submit error:', err);

                alertEl.textContent = 'Failed to submit application. Please try again.';

                alertEl.className = 'alert alert-danger';

                alertEl.style.display = 'block';

                submitBtn.disabled = false;

                submitBtn.innerHTML = originalHtml;

            }

        });



        // Track business type changes so document requirements update correctly

        document.addEventListener('DOMContentLoaded', () => {

            initOriginalRequiredFlags();

            updateRequiredForStep(currentStep);



            const bt = document.querySelector('select[name="businessType"]');

            if (bt) {

                bt.addEventListener('change', () => {

                    updateRequiredForStep(currentStep);

                });

            }

        });

    </script>

</body>

</html>

