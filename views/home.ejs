<!-- Hero Section -->
<%- include('partials/hero-simple') %>

<!-- Features Section -->
<section class="features section">
    <div class="container">
        <div class="section-title">
            <h2>Who Can Apply</h2>
            <p>We support a wide range of businesses and ideas with funding and mentorship</p>
        </div>
        
        <div class="feature-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-rocket"></i>
                </div>
                <h3>Startups</h3>
                <p>Early-stage startups with innovative ideas and high growth potential</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-store"></i>
                </div>
                <h3>Small Businesses</h3>
                <p>Established small businesses looking to expand and scale operations</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-lightbulb"></i>
                </div>
                <h3>Innovative Ideas</h3>
                <p>Individuals with groundbreaking business ideas seeking initial funding</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-industry"></i>
                </div>
                <h3>Manufacturing</h3>
                <p>Manufacturing units seeking modernization and capacity expansion</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-laptop-code"></i>
                </div>
                <h3>Tech Companies</h3>
                <p>Technology companies developing innovative solutions</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-seedling"></i>
                </div>
                <h3>Agriculture</h3>
                <p>Agricultural businesses implementing modern farming techniques</p>
            </div>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section class="how-it-works section">
    <div class="container">
        <div class="section-title">
            <h2>How It Works</h2>
            <p>Simple 4-step process to get your business funded</p>
        </div>
        
        <div class="steps">
            <div class="step">
                <div class="step-number">1</div>
                <h3>Apply Online</h3>
                <p>Submit your business proposal through our online application form</p>
            </div>
            
            <div class="step">
                <div class="step-number">2</div>
                <h3>Review Process</h3>
                <p>Our team reviews your application and business model</p>
            </div>
            
            <div class="step">
                <div class="step-number">3</div>
                <h3>Due Diligence</h3>
                <p>We conduct thorough due diligence and assessment</p>
            </div>
            
            <div class="step">
                <div class="step-number">4</div>
                <h3>Funding & Support</h3>
                <p>Receive funding and ongoing mentorship for growth</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta section">
    <div class="container">
        <h2>Ready to Turn Your Ambition Into an Empire?</h2>
        <p>Join hundreds of entrepreneurs who have transformed their businesses with UdyamKings</p>
        <div class="hero-buttons">
            <a href="/register" class="btn btn-secondary btn-lg">Apply for Funding</a>
            <a href="/contact" class="btn btn-outline btn-lg">Learn More</a>
        </div>
    </div>
</section>
