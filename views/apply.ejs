    text-align: center;
}

.step.active .step-label {
    color: var(--primary);
    font-weight: 600;
}

.step.completed .step-label {
    color: var(--success);
}

/* Application Container */
.application-container {
    padding: 3rem 0;
    background-color: #f8f9fa;
    min-height: calc(100vh - 200px);
}

.application-card {
    border: none;
